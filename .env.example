# ============================================
# .env.example - TEMPLATE PARA PRODUCCION
# ============================================
# 1. Copia este archivo a .env.production
# 2. Rellena los valores
# 3. Deploy: docker compose --env-file .env.production -f docker-compose.prod.yml up --build -d
#
# IMPORTANTE: Nunca subas este archivo a Git. Ya esta en .gitignore.

# --- Dominio ---
# El dominio donde correra tu app (sin https://)
DOMAIN=nutripet.rentshield.cloud

# --- PostgreSQL ---
POSTGRES_USER=nutripet
POSTGRES_PASSWORD=pon_aqui_una_password_segura
POSTGRES_DB=nutripet_production

# --- Rails Secrets ---
# Genera con: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
# Cada vez que generes, te dara un valor diferente. Genera DOS veces.
SECRET_KEY_BASE=genera_con_ruby_y_pega_aqui
DEVISE_JWT_SECRET_KEY=genera_otro_con_ruby_y_pega_aqui
RAILS_ENV=production

# --- CORS ---
# El dominio exacto donde corre tu frontend
CORS_ORIGINS=https://nutripet.rentshield.cloud

# --- Frontend URL ---
# Usado para los links de "forgot password" en los emails
FRONTEND_URL=https://nutripet.rentshield.cloud

# --- SMTP / Email (Resend) ---
# Si dejas estos valores vacios, los emails no se enviaran.
# Para activar: registrate en resend.com, verifica tu dominio, y pega tu API key.
SMTP_ADDRESS=smtp.resend.com
SMTP_PORT=465
SMTP_DOMAIN=nutripet.rentshield.cloud
SMTP_USERNAME=resend
SMTP_PASSWORD=re_tu_api_key_aqui
SMTP_AUTHENTICATION=plain
SMTP_TLS=true
MAILER_SENDER=noreply@nutripet.rentshield.cloud
