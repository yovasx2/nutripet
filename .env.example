# Dominio principal (usado por Traefik)
DOMAIN=nutripet.tudominio.com

# PostgreSQL
POSTGRES_USER=nutripet
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=nutripet_production

# Rails
SECRET_KEY_BASE=genera_con_rails_secret
DEVISE_JWT_SECRET_KEY=genera_con_rails_secret
RAILS_ENV=production

# CORS - dominios permitidos separados por comas
CORS_ORIGINS=https://nutripet.tudominio.com,https://www.nutripet.tudominio.com

# Frontend URL (usado en emails de recuperación)
FRONTEND_URL=https://nutripet.tudominio.com

# SMTP (opcional - si no se configura, los emails no se envían en producción)
# SMTP_ADDRESS=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_DOMAIN=nutripet.tudominio.com
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=tu_api_key
# SMTP_AUTHENTICATION=plain
# SMTP_TLS=true
# MAILER_SENDER=noreply@nutripet.tudominio.com
