# ============================================
# ENVIRONMENT VARIABLES REFERENCE
# ============================================
# Copia este archivo a .env (local) o .env.production (VPS)

# --- General ---
DOMAIN=nutripet.tudominio.com

# --- PostgreSQL ---
POSTGRES_USER=nutripet
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=nutripet_production

# --- Rails ---
# Genera con: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
SECRET_KEY_BASE=genera_con_rails_secret
DEVISE_JWT_SECRET_KEY=genera_con_rails_secret
RAILS_ENV=production

# --- CORS ---
# Dominios permitidos separados por comas
CORS_ORIGINS=https://nutripet.tudominio.com

# --- Frontend URL (para emails de recuperacion) ---
FRONTEND_URL=https://nutripet.tudominio.com

# --- SMTP (opcional - sin esto no se envian emails en produccion) ---
# SMTP_ADDRESS=smtp.resend.com
# SMTP_PORT=465
# SMTP_DOMAIN=nutripet.tudominio.com
# SMTP_USERNAME=resend
# SMTP_PASSWORD=re_tu_api_key
# SMTP_AUTHENTICATION=plain
# SMTP_TLS=true
# MAILER_SENDER=noreply@nutripet.tudominio.com
