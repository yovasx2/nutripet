# ============================================
# PRODUCTION - VPS / Dockploy
# ============================================
# 1. Copy this file: cp .env.production.example .env.production
# 2. Fill in the missing values
# 3. Deploy: docker compose --env-file .env.production -f docker-compose.prod.yml up --build -d
#
# IMPORTANT: Never commit .env.production to Git.

# --- Domain ---
DOMAIN=nutripet.rentshield.cloud

# --- PostgreSQL ---
POSTGRES_USER=nutripet
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=nutripet_production

# --- Rails Secrets ---
# Generate with: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
# Run the command TWICE to get two different values.
SECRET_KEY_BASE=generate_with_ruby_and_paste_here
DEVISE_JWT_SECRET_KEY=generate_another_with_ruby_and_paste_here
RAILS_ENV=production

# --- CORS ---
CORS_ORIGINS=https://nutripet.rentshield.cloud

# --- Frontend URL (password reset links) ---
FRONTEND_URL=https://nutripet.rentshield.cloud

# --- SMTP / Email (Resend) ---
# If SMTP_PASSWORD is left empty, emails will not be sent.
# 1. Sign up at https://resend.com
# 2. Verify your domain in Resend
# 3. Create an API key and paste it here
SMTP_ADDRESS=smtp.resend.com
SMTP_PORT=465
SMTP_DOMAIN=nutripet.rentshield.cloud
SMTP_USERNAME=resend
SMTP_PASSWORD=re_your_api_key_here
SMTP_AUTHENTICATION=plain
SMTP_TLS=true
MAILER_SENDER=noreply@nutripet.rentshield.cloud
