# Development image for hot-reload via Vite dev server
# Builds on top of node:22-alpine but explicitly installs npm
# to work around upstream image corruption on some hosts.

FROM node:22-alpine

# Reinstall npm via apk as a fallback against upstream corruption
RUN apk add --no-cache npm

WORKDIR /app

EXPOSE 3000

CMD ["sh", "-c", "npm install && npm run dev -- --host"]
