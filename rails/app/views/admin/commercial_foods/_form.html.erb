<%# Shared form partial for admin CommercialFood new/edit %>
<%= form_with model: [:admin, food], class: "space-y-6" do |f| %>
  <% if food.errors.any? %>
    <div class="bg-error-container text-red-800 rounded-xl p-4 text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% food.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Basic info -->
  <div class="bg-white rounded-2xl border border-outline-variant p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-on-surface-variant uppercase tracking-wide mb-4">Información básica</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :name, "Nombre del producto", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.text_field :name, placeholder: "Ej. Pedigree Adulto Seco",
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :brand, "Marca", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.text_field :brand, placeholder: "Ej. Mars, Purina, Royal Canin…",
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :species, "Especie", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.select :species, [["Perro", "dog"], ["Gato", "cat"], ["Ambos", "both"]],
              { prompt: "Seleccionar…" },
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :life_stage, "Etapa de vida", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.select :life_stage,
              [["Cachorro", "puppy"], ["Gatito", "kitten"], ["Adulto", "adult"], ["Senior", "senior"],
               ["Gestante", "pregnant"], ["Lactante", "lactating"], ["Todas las etapas", "all_life_stages"]],
              { prompt: "Seleccionar…" },
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :food_form, "Forma del alimento", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.select :food_form, [["Seco (croquetas)", "dry"], ["Húmedo (lata/sobre)", "wet"], ["Semi-húmedo", "semi_moist"]],
              { prompt: "Seleccionar…" },
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :label_standard, "Estándar regulatorio", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.select :label_standard, CommercialFood::LABEL_STANDARDS,
              { include_blank: "No especificado" },
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
    </div>
  </div>

  <!-- Guaranteed Analysis (Análisis Garantizado) -->
  <div class="bg-white rounded-2xl border border-outline-variant p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-on-surface-variant uppercase tracking-wide mb-1">Análisis garantizado</h2>
    <p class="text-xs text-on-surface-variant mb-4">Valores tal como aparecen en la etiqueta del producto (as-fed basis)</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <div>
        <%= f.label :protein_min_pct, "Proteína cruda mín (%)", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.number_field :protein_min_pct, step: 0.1, min: 0, max: 100,
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :fat_min_pct, "Grasa cruda mín (%)", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.number_field :fat_min_pct, step: 0.1, min: 0, max: 100,
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :fiber_max_pct, "Fibra cruda máx (%)", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.number_field :fiber_max_pct, step: 0.1, min: 0, max: 100,
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :moisture_max_pct, "Humedad máx (%)", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.number_field :moisture_max_pct, step: 0.1, min: 0, max: 100,
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :energy_kcal_per_kg, "Energía (kcal ME / kg)", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.number_field :energy_kcal_per_kg, step: 10, min: 0,
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
    </div>
  </div>

  <!-- Ingredient list & notes -->
  <div class="bg-white rounded-2xl border border-outline-variant p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-on-surface-variant uppercase tracking-wide mb-4">Lista de ingredientes y notas</h2>
    <div class="space-y-4">
      <div>
        <%= f.label :ingredients_list, "Lista de ingredientes (del empaque)", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.text_area :ingredients_list, rows: 3,
              placeholder: "Harina de pollo, maíz, subproductos de pollo…",
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-y" %>
      </div>
      <div>
        <%= f.label :source, "Fuente de datos", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.text_field :source, placeholder: "Ej. Etiqueta del producto, sitio oficial, PROFECO…",
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div>
        <%= f.label :notes, "Notas adicionales", class: "block text-sm font-medium text-on-background mb-1" %>
        <%= f.text_area :notes, rows: 2,
              class: "w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-y" %>
      </div>
    </div>
  </div>

  <!-- Status -->
  <div class="flex items-center gap-3 px-1">
    <%= f.check_box :is_active, class: "w-4 h-4 rounded text-primary focus:ring-primary" %>
    <%= f.label :is_active, "Producto activo (visible en el motor de recomendación)", class: "text-sm font-medium text-on-background" %>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit food.persisted? ? "Guardar cambios" : "Crear alimento",
          class: "inline-flex items-center gap-2 bg-primary text-white text-sm font-semibold px-5 py-2.5 rounded-xl hover:opacity-90 transition-opacity cursor-pointer" %>
    <%= link_to "Cancelar", admin_commercial_foods_path,
          class: "text-sm text-on-surface-variant hover:underline" %>
  </div>
<% end %>
