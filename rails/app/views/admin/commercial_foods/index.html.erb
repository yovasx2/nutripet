<% content_for :title, "Alimentos comerciales" %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-on-background">Alimentos comerciales</h1>
      <p class="text-sm text-on-surface-variant mt-1">Catálogo de alimentos procesados con análisis garantizado</p>
    </div>
    <%= link_to new_admin_commercial_food_path,
          class: "inline-flex items-center gap-2 bg-primary text-white text-sm font-semibold px-4 py-2.5 rounded-xl hover:opacity-90 transition-opacity" do %>
      <span class="material-symbols-outlined text-base leading-none">add</span>
      Agregar alimento
    <% end %>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-2xl border border-outline-variant shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-surface-low border-b border-outline-variant">
        <tr>
          <th class="text-left px-5 py-3 font-semibold text-on-surface-variant uppercase tracking-wide text-xs">Nombre / Marca</th>
          <th class="text-left px-4 py-3 font-semibold text-on-surface-variant uppercase tracking-wide text-xs">Especie</th>
          <th class="text-left px-4 py-3 font-semibold text-on-surface-variant uppercase tracking-wide text-xs">Etapa / Forma</th>
          <th class="text-right px-4 py-3 font-semibold text-on-surface-variant uppercase tracking-wide text-xs">Proteína mín</th>
          <th class="text-right px-4 py-3 font-semibold text-on-surface-variant uppercase tracking-wide text-xs">Grasa mín</th>
          <th class="text-right px-4 py-3 font-semibold text-on-surface-variant uppercase tracking-wide text-xs">Fibra máx</th>
          <th class="text-right px-4 py-3 font-semibold text-on-surface-variant uppercase tracking-wide text-xs">kcal / kg</th>
          <th class="text-center px-4 py-3 font-semibold text-on-surface-variant uppercase tracking-wide text-xs">Estado</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-surface-highest">
        <% @commercial_foods.each do |food| %>
          <tr class="hover:bg-surface-low transition-colors">
            <td class="px-5 py-3">
              <span class="font-medium text-on-background"><%= food.name %></span>
              <% if food.brand.present? %>
                <span class="block text-xs text-on-surface-variant"><%= food.brand %></span>
              <% end %>
            </td>
            <td class="px-4 py-3 capitalize text-on-background">
              <%= { "dog" => "Perro", "cat" => "Gato", "both" => "Ambos" }[food.species] || food.species %>
            </td>
            <td class="px-4 py-3 text-on-background">
              <span class="block capitalize"><%= food.life_stage.to_s.humanize.downcase %></span>
              <span class="text-xs text-on-surface-variant"><%= food.form_label %></span>
            </td>
            <td class="px-4 py-3 text-right font-mono text-on-background">
              <%= food.protein_min_pct.present? ? "#{food.protein_min_pct}%" : "—" %>
            </td>
            <td class="px-4 py-3 text-right font-mono text-on-background">
              <%= food.fat_min_pct.present? ? "#{food.fat_min_pct}%" : "—" %>
            </td>
            <td class="px-4 py-3 text-right font-mono text-on-background">
              <%= food.fiber_max_pct.present? ? "#{food.fiber_max_pct}%" : "—" %>
            </td>
            <td class="px-4 py-3 text-right font-mono text-on-background">
              <%= food.energy_kcal_per_kg.present? ? food.energy_kcal_per_kg.to_i : "—" %>
            </td>
            <td class="px-4 py-3 text-center">
              <% if food.is_active %>
                <span class="inline-block bg-green-100 text-green-800 text-xs font-semibold px-2.5 py-0.5 rounded-full">Activo</span>
              <% else %>
                <span class="inline-block bg-surface-highest text-on-surface-variant text-xs font-semibold px-2.5 py-0.5 rounded-full">Inactivo</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right whitespace-nowrap">
              <%= link_to "Editar", edit_admin_commercial_food_path(food),
                    class: "text-xs text-primary font-semibold hover:underline mr-3" %>
              <%= button_to "Eliminar", admin_commercial_food_path(food),
                    method: :delete,
                    data: { turbo_confirm: "¿Eliminar #{food.name}? Esta acción no se puede deshacer." },
                    class: "text-xs text-red-600 font-semibold hover:underline" %>
            </td>
          </tr>
        <% end %>
        <% if @commercial_foods.empty? %>
          <tr>
            <td colspan="9" class="px-5 py-10 text-center text-sm text-on-surface-variant">
              No hay alimentos comerciales registrados. <%= link_to "Agregar el primero", new_admin_commercial_food_path, class: "text-primary hover:underline" %>.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
