<!DOCTYPE html>
<html class="light" lang="es">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Admin Dashboard - NutriPet</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script id="tailwind-config">
    tailwind.config = {darkMode: "class", theme: {extend: {colors: {primary: "#005d90", "on-primary": "#ffffff", "primary-container": "#0077b6", "on-primary-container": "#f3f7ff", secondary: "#00677d", "on-secondary": "#ffffff", "secondary-container": "#50d9fe", "on-secondary-container": "#005c70", tertiary: "#00626f", "on-tertiary": "#ffffff", "tertiary-container": "#227c8a", "on-tertiary-container": "#e7fbff", error: "#ba1a1a", "on-error": "#ffffff", "error-container": "#ffdad6", "on-error-container": "#93000a", background: "#eefcff", "on-background": "#001f24", surface: "#eefcff", "on-surface": "#001f24", "surface-variant": "#c3e9f1", "on-surface-variant": "#404850", outline: "#707881", "outline-variant": "#bfc7d1", "surface-container-lowest": "#ffffff", "surface-container-low": "#dcf9ff", "surface-container": "#cef5fd", "surface-container-high": "#c9eff7", "surface-container-highest": "#c3e9f1", "primary-fixed-dim": "#94ccff", "on-tertiary-fixed-variant": "#004f59", "inverse-surface": "#0e353c", "secondary-fixed-dim": "#4cd6fb", "surface-tint": "#006399", "on-tertiary-fixed": "#001f24", "on-secondary-fixed": "#001f27", "on-primary-fixed": "#004b74", "primary-fixed": "#cde5ff", "inverse-on-surface": "#d2f7ff", "surface-bright": "#eefcff", "on-primary-fixed-variant": "#004b74", "primary-fixed": "#cde5ff", "inverse-primary": "#94ccff", "tertiary-fixed": "#9feffe", "surface-dim": "#bbe1e8", "tertiary-fixed-dim": "#83d3e1", "on-secondary-fixed-variant": "#004e5f"}, borderRadius: {DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px"}, fontFamily: {headline: ["Plus Jakarta Sans"], body: ["Plus Jakarta Sans"], label: ["Plus Jakarta Sans"], display: "Plus Jakarta Sans"}}}};
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .glass-nav { background: rgba(248, 250, 253, 0.6); backdrop-filter: blur(12px); }
    .restorative-mesh { background-image: radial-gradient(at 0% 0%, #B0C4DE 0%, transparent 50%), radial-gradient(at 100% 100%, #d6e4f0 0%, transparent 50%); opacity: 0.3; }
  </style>
</head>
<body class="bg-surface text-on-surface antialiased">
<%= render 'shared/navbar' %>
<main class="relative pt-16 overflow-hidden min-h-screen">
  <div class="absolute inset-0 restorative-mesh -z-10"></div>
  <div class="px-6 py-16 max-w-screen-2xl mx-auto">
    <div class="bg-surface-container rounded-[2rem] shadow-sm border border-outline-variant overflow-hidden">
      <div class="p-8 md:p-12">
        <div class="text-center mb-10">
          <h1 class="font-headline text-4xl font-extrabold text-on-surface tracking-tight mb-4">Panel de Administración</h1>
          <p class="text-on-surface-variant text-lg max-w-2xl mx-auto">Accede al gestor de recetas y controla los contenidos críticos de NutriPet como superadmin.</p>
        </div>
        <div class="grid gap-6 lg:grid-cols-3">
          <div class="p-6 rounded-[2rem] border border-surface-container bg-surface-container-lowest shadow-sm">
            <span class="material-symbols-outlined text-primary text-4xl">restaurant_menu</span>
            <h2 class="mt-6 text-2xl font-bold">Recetas Maestras</h2>
            <p class="text-on-surface-variant mt-3">Administra las fórmulas nutricionales que usan los veterinarios.</p>
            <div class="mt-6">
              <%= link_to 'Ir a Recetas', admin_recipes_path, class: 'inline-flex items-center gap-2 px-5 py-3 rounded-full bg-primary text-white font-bold hover:bg-primary-container transition-all' %>
            </div>
          </div>
          <div class="p-6 rounded-[2rem] border border-surface-container bg-surface-container-lowest shadow-sm">
            <span class="material-symbols-outlined text-primary text-4xl">person</span>
            <h2 class="mt-6 text-2xl font-bold">Usuarios</h2>
            <p class="text-on-surface-variant mt-3">Revisa el acceso y los roles del equipo clínico.</p>
            <div class="mt-6">
              <button class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-surface-container-high text-on-surface font-bold border border-surface-container hover:bg-surface-container transition-all" disabled>Próximamente</button>
            </div>
          </div>
          <div class="p-6 rounded-[2rem] border border-surface-container bg-surface-container-lowest shadow-sm">
            <span class="material-symbols-outlined text-primary text-4xl">analytics</span>
            <h2 class="mt-6 text-2xl font-bold">Informes</h2>
            <p class="text-on-surface-variant mt-3">Monitorea el rendimiento de los planes y recetas.</p>
            <div class="mt-6">
              <button class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-surface-container-high text-on-surface font-bold border border-surface-container hover:bg-surface-container transition-all" disabled>Próximamente</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
<%= render 'shared/footer' %>
</body>
</html>
