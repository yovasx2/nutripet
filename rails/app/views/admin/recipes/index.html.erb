<!DOCTYPE html>
<html class="light" lang="es">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Recetas Maestras - NutriPet Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script id="tailwind-config">
    tailwind.config = {darkMode: "class", theme: {extend: {colors: {primary: "#005d90", "on-primary": "#ffffff", "primary-container": "#0077b6", "on-primary-container": "#f3f7ff", secondary: "#00677d", "on-secondary": "#ffffff", "secondary-container": "#50d9fe", "on-secondary-container": "#005c70", tertiary: "#00626f", "on-tertiary": "#ffffff", "tertiary-container": "#227c8a", "on-tertiary-container": "#e7fbff", error: "#ba1a1a", "on-error": "#ffffff", "error-container": "#ffdad6", "on-error-container": "#93000a", background: "#eefcff", "on-background": "#001f24", surface: "#eefcff", "on-surface": "#001f24", "surface-variant": "#c3e9f1", "on-surface-variant": "#404850", outline: "#707881", "outline-variant": "#bfc7d1", "surface-container-lowest": "#ffffff", "surface-container-low": "#dcf9ff", "surface-container": "#cef5fd", "surface-container-high": "#c9eff7", "surface-container-highest": "#c3e9f1", "primary-fixed-dim": "#94ccff", "on-tertiary-fixed-variant": "#004f59", "inverse-surface": "#0e353c", "secondary-fixed-dim": "#4cd6fb", "surface-tint": "#006399", "on-tertiary-fixed": "#001f24", "on-secondary-fixed": "#001f27", "on-primary-fixed": "#004b74", "primary-fixed": "#cde5ff", "inverse-on-surface": "#d2f7ff", "surface-bright": "#eefcff", "on-primary-fixed-variant": "#004b74", "primary-fixed": "#cde5ff", "inverse-primary": "#94ccff", "tertiary-fixed": "#9feffe", "surface-dim": "#bbe1e8", "tertiary-fixed-dim": "#83d3e1", "on-secondary-fixed-variant": "#004e5f"}, borderRadius: {DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px"}, fontFamily: {headline: ["Plus Jakarta Sans"], body: ["Plus Jakarta Sans"], label: ["Plus Jakarta Sans"], display: "Plus Jakarta Sans"}}}};
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .glass-nav { background: rgba(248, 250, 253, 0.6); backdrop-filter: blur(12px); }
    .restorative-mesh { background-image: radial-gradient(at 0% 0%, #B0C4DE 0%, transparent 50%), radial-gradient(at 100% 100%, #d6e4f0 0%, transparent 50%); opacity: 0.3; }
  </style>
</head>
<body class="bg-surface text-on-surface antialiased">
<%= render 'shared/navbar' %>
<main class="relative pt-16 overflow-hidden min-h-screen">
  <div class="absolute inset-0 restorative-mesh -z-10"></div>
  <div class="px-6 py-16 max-w-screen-2xl mx-auto">
    <div class="flex items-center justify-between gap-4 mb-10">
      <div>
        <h1 class="font-headline text-4xl font-extrabold text-on-surface tracking-tight">Recetas Maestras</h1>
        <p class="text-on-surface-variant mt-2">Panel de gestión de recetas disponible para superadmins.</p>
      </div>
      <div>
        <button class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary text-white font-bold hover:bg-primary-container transition-all">
          <span class="material-symbols-outlined">add</span>
          Nueva Receta
        </button>
      </div>
    </div>
    <div class="bg-surface-container rounded-[2rem] border border-outline-variant shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-surface-container">
          <thead class="bg-surface-container-lowest">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Nombre</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Proteína</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Kcal/100g</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Estado</th>
              <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-surface-container">
            <% @recipes.each do |recipe| %>
              <tr class="hover:bg-surface-container-low/50 transition-colors">
                <td class="px-6 py-4 font-semibold"><%= recipe[:name] %></td>
                <td class="px-6 py-4"><%= recipe[:protein] %></td>
                <td class="px-6 py-4"><%= recipe[:kcal] %></td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= recipe[:status] == 'Activa' ? 'bg-success-container text-on-success-container' : 'bg-surface-container text-on-surface' %>"><%= recipe[:status] %></span>
                </td>
                <td class="px-6 py-4 text-right">
                  <button class="px-4 py-2 rounded-full bg-surface-container text-on-surface font-semibold hover:bg-surface-container-high transition-all">Editar</button>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>
<%= render 'shared/footer' %>
</body>
</html>
