<% content_for :title, "Elegir dieta para #{@pet.name}" %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <!-- Back -->
  <div class="mb-6">
    <%= link_to "← #{@pet.name}", pet_path(@pet), class: "text-sm text-primary font-medium hover:underline" %>
  </div>

  <!-- Header -->
  <%
    auto_std_name    = @pet.species == "dog" ? "AAFCO" : "FEDIAF"
    auto_std_version = auto_std_name == "NRC" ? "2006" : "2023"
    std_urls = {
      "AAFCO"  => "https://www.aafco.org/",
      "FEDIAF" => "https://europeanpetfood.org/",
      "NRC"    => "https://nap.nationalacademies.org/"
    }
    used_std_name = @options[:standard_name].presence || auto_std_name
  %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-on-background">Elige una propuesta nutricional</h1>
    <p class="text-sm text-on-surface-variant mt-1">
      Generamos <%= @proposals.size %> opciones adaptadas al perfil de <strong><%= @pet.name %></strong>
      (<%= @pet.species == "dog" ? "Perro" : "Gato" %> · <%= @pet.life_stage %> · <%= @pet.weight_kg %> kg).
      Cada propuesta varía la fuente de proteína principal.
    </p>
    <!-- Active standard badge -->
    <div class="flex items-center gap-1.5 mt-3">
      <span class="text-xs text-on-surface-variant">Estándar aplicado:</span>
      <a href="<%= std_urls[used_std_name] %>" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:underline">
        <%= used_std_name %> <%= used_std_name == "NRC" ? "2006" : "2023" %>
        <span class="material-symbols-outlined text-xs leading-none">open_in_new</span>
      </a>
      <% if @options[:standard_name].blank? %>
        <span class="text-xs text-on-surface-variant">(seleccionado automáticamente para <%= @pet.species == "dog" ? "perros" : "gatos" %>)</span>
      <% end %>
    </div>
  </div>

  <!-- Settings card — diet type + prep style (standard is always auto on first pass) -->
  <details class="bg-white rounded-2xl border border-outline-variant shadow-sm mb-6 group" <%= @options[:diet_type] != "homemade" || @options[:preparation_style] != "cooked" ? "open" : "" %>>
    <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-secondary text-base leading-none">tune</span>
        <span class="text-sm font-semibold text-on-background">Personalizar propuestas</span>
        <% if @options[:diet_type] != "homemade" || @options[:preparation_style] != "cooked" %>
          <span class="bg-primary text-white text-xs font-bold px-2 py-0.5 rounded-full">activos</span>
        <% end %>
      </div>
      <span class="material-symbols-outlined text-on-surface-variant text-base group-open:rotate-180 transition-transform">expand_more</span>
    </summary>

    <%= form_with url: new_pet_diet_prescription_path(@pet), method: :get, class: "px-5 pb-5 space-y-5 border-t border-surface-highest pt-5" do |f| %>
      <!-- Standard name carried through as hidden — stays nil (auto) unless explicitly set via regenerate -->
      <input type="hidden" name="standard_name" value="<%= @options[:standard_name] %>">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <!-- Diet type -->
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Tipo de dieta</label>
          <div class="space-y-1.5">
            <% [["homemade", "🍳 Casera (ingredientes frescos)"], ["commercial", "🛒 Alimento comercial"], ["mixed", "🔀 Mixta (casera + comercial)"]].each do |val, label| %>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="diet_type" value="<%= val %>"
                       <%= "checked" if @options[:diet_type] == val %>
                       class="w-4 h-4 text-primary focus:ring-primary">
                <span class="text-sm text-on-background"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <!-- Preparation style -->
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Estilo de preparación</label>
          <div class="space-y-1.5">
            <% [["cooked", "🔥 Cocida (proteínas y verduras cocidas)"], ["raw", "🥩 BARF / cruda (ingredientes crudos raw-safe)"], ["mixed", "⚖️ Mixta (cruda + cocida)"]].each do |val, label| %>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="preparation_style" value="<%= val %>"
                       <%= "checked" if @options[:preparation_style] == val %>
                       class="w-4 h-4 text-primary focus:ring-primary">
                <span class="text-sm text-on-background"><%= label %></span>
              </label>
            <% end %>
          </div>
          <p class="text-xs text-on-surface-variant mt-2 italic">La opción BARF solo incluye ingredientes certificados como raw-safe.</p>
        </div>
      </div>

      <!-- Custom notes -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2 border-t border-surface-highest">
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-1.5">Notas sobre alérgenos</label>
          <textarea name="custom_allergens_notes" rows="2"
            placeholder="Ej. Evitar pollo y trigo por sensibilidad conocida…"
            class="w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none"><%= params[:custom_allergens_notes] %></textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-1.5">Notas sobre condiciones</label>
          <textarea name="custom_conditions_notes" rows="2"
            placeholder="Ej. Heces blandas frecuentes, digestión lenta…"
            class="w-full border border-outline-variant rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none"><%= params[:custom_conditions_notes] %></textarea>
        </div>
      </div>

      <button type="submit"
        class="inline-flex items-center gap-2 bg-primary text-white text-sm font-semibold px-4 py-2 rounded-xl hover:opacity-90 transition-opacity">
        <span class="material-symbols-outlined text-base leading-none">refresh</span>
        Regenerar propuestas
      </button>
    <% end %>
  </details>

  <!-- Proposal cards -->
  <div class="grid grid-cols-1 sm:grid-cols-<%= [@proposals.size, 3].min %> gap-5">
    <% @proposals.each_with_index do |proposal, i| %>
      <%
        accent_colors = ["bg-primary", "bg-secondary", "bg-primary-container"]
        accent = accent_colors[i % accent_colors.size]
      %>

      <% if proposal.respond_to?(:energy_kcal_per_kg) %>
        <%# ── COMMERCIAL FOOD CARD ── %>
        <div class="bg-white rounded-2xl border border-outline-variant shadow-sm overflow-hidden flex flex-col">
          <div class="h-1.5 <%= accent %>"></div>
          <div class="p-5 flex flex-col flex-1">
            <div class="mb-4">
              <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Opción <%= i + 1 %> · <%= proposal.form_label %></span>
              <h2 class="text-base font-bold text-on-background mt-1 leading-tight"><%= proposal.name %></h2>
              <% if proposal.brand.present? %>
                <p class="text-xs text-on-surface-variant mt-0.5">Marca: <strong><%= proposal.brand %></strong></p>
              <% end %>
            </div>

            <!-- Guaranteed analysis -->
            <div class="grid grid-cols-2 gap-2 mb-5">
              <% if proposal.protein_min_pct.present? %>
                <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
                  <span class="block font-bold text-on-background text-sm"><%= proposal.protein_min_pct %>%</span>
                  <span class="text-xs text-on-surface-variant">Proteína mín</span>
                </div>
              <% end %>
              <% if proposal.fat_min_pct.present? %>
                <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
                  <span class="block font-bold text-on-background text-sm"><%= proposal.fat_min_pct %>%</span>
                  <span class="text-xs text-on-surface-variant">Grasa mín</span>
                </div>
              <% end %>
              <% if proposal.fiber_max_pct.present? %>
                <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
                  <span class="block font-bold text-on-background text-sm"><%= proposal.fiber_max_pct %>%</span>
                  <span class="text-xs text-on-surface-variant">Fibra máx</span>
                </div>
              <% end %>
              <% if proposal.energy_kcal_per_kg.present? %>
                <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
                  <span class="block font-bold text-on-background text-sm"><%= proposal.energy_kcal_per_kg.to_i %></span>
                  <span class="text-xs text-on-surface-variant">kcal / kg</span>
                </div>
              <% end %>
            </div>

            <div class="mt-auto">
              <%= button_to pet_diet_prescriptions_path(@pet),
                    params: {
                      commercial_food_id: proposal.id,
                      diet_type: @options[:diet_type],
                      preparation_style: @options[:preparation_style],
                      standard_name: @options[:standard_name]
                    },
                    method: :post,
                    class: "w-full inline-flex items-center justify-center gap-2 bg-primary text-white text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-primary-container transition-colors" do %>
                <span class="material-symbols-outlined text-base leading-none">shopping_cart</span>
                Elegir este alimento
              <% end %>
            </div>
          </div>
        </div>

      <% else %>
        <%# ── HOMEMADE FORMULA CARD ── %>
        <%
          formula = DietFormula.find_by(fingerprint: proposal.fingerprint) ||
                    DietFormula.find_by("fingerprint LIKE ?", "#{DietFormula.generate_fingerprint(@pet)}_#{i}")
          next unless formula

          macros = proposal.macros.any? ? proposal.macros : begin
            composition_with_objects = formula.ingredient_composition.map { |id, pct| [Ingredient.find_by(id: id.to_i), pct.to_f] }.compact
            portions = DietEngine::FormulaPortionCalculator.new(composition_with_objects, DietEngine::DerCalculator.new(@pet).der).calculate
            portions.macro_summary
          rescue
            {}
          end

          protein_main = formula.ingredient_composition.max_by { |_, pct| pct.to_f }&.then { |id, _| Ingredient.find_by(id: id.to_i)&.name } || "Proteína"
        %>
        <div class="bg-white rounded-2xl border border-outline-variant shadow-sm overflow-hidden flex flex-col">
          <!-- Color top bar -->
          <div class="h-1.5 <%= accent %>"></div>

          <div class="p-5 flex flex-col flex-1">
            <!-- Title -->
            <div class="mb-4">
              <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Opción <%= i + 1 %></span>
              <h2 class="text-base font-bold text-on-background mt-1 leading-tight"><%= formula.name || proposal.name %></h2>
              <p class="text-xs text-on-surface-variant mt-0.5">Proteína principal: <strong><%= protein_main %></strong></p>
            </div>

            <!-- Ingredient composition -->
            <div class="mb-4">
              <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Composición</p>
              <div class="space-y-1.5">
                <% formula.ingredient_composition.sort_by { |_, pct| -pct.to_f }.each do |ing_id, pct| %>
                  <% ing = Ingredient.find_by(id: ing_id.to_i) %>
                  <% next unless ing %>
                  <div class="flex items-center gap-2 text-xs">
                    <!-- Visual bar -->
                    <div class="flex-1 bg-surface-highest rounded-full h-1.5">
                      <div class="<%= accent %> h-1.5 rounded-full" style="width: <%= [pct.to_f, 100].min %>%"></div>
                    </div>
                    <span class="text-on-surface-variant w-24 truncate text-right"><%= ing.name.split(" ").first(2).join(" ") %></span>
                    <span class="font-semibold text-on-background w-8 text-right"><%= pct.to_f.round %>%</span>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Macro summary -->
            <% if macros.any? %>
              <div class="grid grid-cols-2 gap-2 mb-5">
                <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
                  <span class="block font-bold text-on-background text-sm"><%= macros[:protein_g].to_f.round(1) %>g</span>
                  <span class="text-xs text-on-surface-variant">Proteína / 100g</span>
                </div>
                <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
                  <span class="block font-bold text-on-background text-sm"><%= macros[:fat_g].to_f.round(1) %>g</span>
                  <span class="text-xs text-on-surface-variant">Grasa / 100g</span>
                </div>
                <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
                  <span class="block font-bold text-on-background text-sm"><%= macros[:carbs_g].to_f.round(1) %>g</span>
                  <span class="text-xs text-on-surface-variant">Carbos / 100g</span>
                </div>
                <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
                  <span class="block font-bold text-on-background text-sm"><%= macros[:energy_kcal].to_f.round %>kcal</span>
                  <span class="text-xs text-on-surface-variant">Energía / 100g</span>
                </div>
              </div>
            <% end %>

            <!-- Upvotes badge -->
            <% if formula.upvotes_count > 0 %>
              <p class="text-xs text-on-surface-variant mb-3">
                <span class="material-symbols-outlined text-xs align-middle text-secondary">thumb_up</span>
                <%= formula.upvotes_count %> dueños valoraron esta fórmula positivamente
              </p>
            <% end %>

            <!-- Select CTA -->
            <div class="mt-auto">
              <%= button_to pet_diet_prescriptions_path(@pet),
                    params: {
                      formula_id: formula.id,
                      diet_type: @options[:diet_type],
                      preparation_style: @options[:preparation_style],
                      standard_name: @options[:standard_name]
                    },
                    method: :post,
                    class: "w-full inline-flex items-center justify-center gap-2 bg-primary text-white text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-primary-container transition-colors" do %>
                <span class="material-symbols-outlined text-base leading-none">check_circle</span>
                Elegir esta dieta
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Help note -->
  <p class="text-xs text-on-surface-variant text-center mt-6">
    Las propuestas excluyen ingredientes tóxicos y alérgenos de <%= @pet.name %>.
    Las fórmulas con más valoraciones aparecerán primero en el futuro.
  </p>
</div>
