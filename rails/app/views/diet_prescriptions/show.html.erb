<% content_for :title, "Dieta de #{@pet.name}" %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <!-- Back -->
  <div class="mb-6">
    <%= link_to "← Perfil de #{@pet.name}", pet_path(@pet), class: "text-sm text-primary font-medium hover:underline" %>
  </div>

  <!-- Header card -->
  <div class="bg-primary rounded-2xl p-6 text-white mb-6">
    <div class="flex items-start justify-between">
      <div>
        <p class="text-sm opacity-80 uppercase tracking-wider font-medium mb-1">Prescripción Nutricional</p>
        <h1 class="text-2xl font-bold"><%= @pet.name %></h1>
        <p class="text-sm opacity-80 mt-1 capitalize"><%= @pet.species %> · <%= @pet.life_stage %> · <%= @pet.weight_kg %> kg</p>
        <!-- Diet type + prep style badges -->
        <div class="flex flex-wrap gap-2 mt-2">
          <% if @prescription.respond_to?(:diet_type) && @prescription.diet_type.present? %>
            <span class="inline-block bg-white/20 text-white text-xs font-semibold px-2.5 py-0.5 rounded-full"><%= @prescription.diet_type_label %></span>
          <% end %>
          <% if @prescription.respond_to?(:preparation_style) && @prescription.preparation_style.present? %>
            <span class="inline-block bg-white/20 text-white text-xs font-semibold px-2.5 py-0.5 rounded-full"><%= @prescription.prep_style_label %></span>
          <% end %>
        </div>
      </div>
      <div class="text-right">
        <% if @prescription.ai_refined? %>
          <span class="inline-block bg-secondary-container text-on-secondary-container text-xs font-semibold px-3 py-1 rounded-full">
            IA + Motor
          </span>
        <% else %>
          <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">
            Motor determinístico
          </span>
        <% end %>
        <p class="text-xs opacity-70 mt-2"><%= l @prescription.created_at, format: :long rescue @prescription.created_at.strftime("%d/%m/%Y %H:%M") %></p>
      </div>
    </div>

    <!-- Energy summary -->
    <%
      std_urls = {
        "AAFCO"  => "https://www.aafco.org/",
        "FEDIAF" => "https://europeanpetfood.org/",
        "NRC"    => "https://nap.nationalacademies.org/"
      }
      std_name = @prescription.nutritional_standard.standard_name
      std_url  = std_urls[std_name]
    %>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-5">
      <div class="bg-white/10 rounded-xl px-3 py-2 text-center">
        <span class="block font-bold text-xl"><%= @prescription.der_kcal.to_i %></span>
        <span class="text-xs opacity-80">kcal / día</span>
      </div>
      <div class="bg-white/10 rounded-xl px-3 py-2 text-center">
        <span class="block font-bold text-xl"><%= @prescription.daily_portion_g.to_i %>g</span>
        <span class="text-xs opacity-80">porción / día</span>
      </div>
      <div class="bg-white/10 rounded-xl px-3 py-2 text-center">
        <span class="block font-bold text-lg"><%= @prescription.recipe_name %></span>
        <span class="text-xs opacity-80">fórmula base</span>
      </div>
      <div class="bg-white/10 rounded-xl px-3 py-2 text-center">
        <% if std_url.present? %>
          <a href="<%= std_url %>" target="_blank" rel="noopener noreferrer"
             class="block font-bold text-lg hover:underline underline-offset-2">
            <%= std_name %> <%= @prescription.nutritional_standard.version %>
            <span class="material-symbols-outlined text-xs align-middle opacity-70">open_in_new</span>
          </a>
        <% else %>
          <span class="block font-bold text-lg"><%= std_name %> <%= @prescription.nutritional_standard.version %></span>
        <% end %>
        <span class="text-xs opacity-80">estándar</span>
      </div>
    </div>
  </div>

  <!-- Macros summary -->
  <% macros = (@prescription.display_output["macros"] || {}).symbolize_keys %>
  <% if macros.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
      <div class="bg-white rounded-2xl border border-outline-variant p-4 text-center">
        <span class="material-symbols-outlined text-2xl text-secondary mb-1 block">science</span>
        <span class="block font-bold text-on-background text-lg"><%= macros[:protein_g].to_f.round(1) %>g</span>
        <span class="text-xs text-on-surface-variant">Proteína</span>
      </div>
      <div class="bg-white rounded-2xl border border-outline-variant p-4 text-center">
        <span class="material-symbols-outlined text-2xl text-secondary mb-1 block">water_drop</span>
        <span class="block font-bold text-on-background text-lg"><%= macros[:fat_g].to_f.round(1) %>g</span>
        <span class="text-xs text-on-surface-variant">Grasa</span>
      </div>
      <div class="bg-white rounded-2xl border border-outline-variant p-4 text-center">
        <span class="material-symbols-outlined text-2xl text-secondary mb-1 block">grain</span>
        <span class="block font-bold text-on-background text-lg"><%= macros[:carbs_g].to_f.round(1) %>g</span>
        <span class="text-xs text-on-surface-variant">Carbohidratos</span>
      </div>
      <div class="bg-white rounded-2xl border border-outline-variant p-4 text-center">
        <span class="material-symbols-outlined text-2xl text-secondary mb-1 block">nutrition</span>
        <span class="block font-bold text-on-background text-lg"><%= macros[:fiber_g].to_f.round(1) %>g</span>
        <span class="text-xs text-on-surface-variant">Fibra</span>
      </div>
    </div>
  <% end %>

  <!-- Ingredient list -->
  <div class="bg-white rounded-2xl border border-outline-variant shadow-sm mb-6">
    <div class="px-6 py-4 border-b border-surface-highest">
      <h2 class="text-base font-bold text-on-background">Ingredientes diarios</h2>
      <p class="text-xs text-on-surface-variant mt-0.5">Cantidades para una porción diaria total de <%= @prescription.daily_portion_g.to_i %>g</p>
    </div>
    <div class="divide-y divide-surface-highest">
      <% @items.each do |item| %>
        <div class="px-6 py-3 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <% if item.is_substitute %>
              <span class="w-2 h-2 rounded-full bg-secondary shrink-0"></span>
            <% else %>
              <span class="w-2 h-2 rounded-full bg-primary shrink-0"></span>
            <% end %>
            <div>
              <span class="text-sm font-medium text-on-background"><%= item.ingredient.name %></span>
              <% if item.is_substitute %>
                <span class="ml-2 text-xs bg-secondary-container text-on-secondary-container px-2 py-0.5 rounded-full">sustituto IA</span>
              <% end %>
            </div>
          </div>
          <div class="text-right shrink-0 ml-4">
            <span class="text-sm font-bold text-on-background"><%= item.daily_amount_g.to_f.round(1) %> g</span>
            <span class="block text-xs text-on-surface-variant"><%= item.pct_of_diet.to_f.round(1) %>%</span>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Preparation notes -->
  <% if @prescription.preparation_notes.present? %>
    <div class="bg-white rounded-2xl border border-outline-variant shadow-sm mb-6 p-6">
      <h2 class="text-base font-bold text-on-background mb-3">
        <span class="material-symbols-outlined text-secondary align-middle mr-1">skillet</span>
        Preparación
      </h2>
      <p class="text-sm text-on-surface-variant leading-relaxed">
        <%= @prescription.preparation_notes %>
      </p>
    </div>
  <% end %>

  <!-- Feeding schedule (from LLM if available) -->
  <% output = @prescription.display_output %>
  <% if output["feeding_schedule"].present? %>
    <div class="bg-white rounded-2xl border border-outline-variant shadow-sm mb-6 p-6">
      <h2 class="text-base font-bold text-on-background mb-3">
        <span class="material-symbols-outlined text-secondary align-middle mr-1">schedule</span>
        Horario de alimentación
      </h2>
      <p class="text-sm text-on-surface-variant leading-relaxed"><%= output["feeding_schedule"] %></p>
    </div>
  <% end %>

  <!-- Clinical notes (from LLM or conditions) -->
  <% if output["clinical_notes"].present? || @pet.has_conditions? %>
    <div class="bg-surface-low border border-outline-variant rounded-2xl p-6 mb-6">
      <h2 class="text-base font-bold text-on-background mb-3">
        <span class="material-symbols-outlined text-error align-middle mr-1">warning</span>
        Notas clínicas
      </h2>
      <% if output["clinical_notes"].present? %>
        <p class="text-sm text-on-surface-variant leading-relaxed mb-3"><%= output["clinical_notes"] %></p>
      <% end %>
      <% if @pet.has_conditions? %>
        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wide mb-2">Condiciones activas</p>
        <div class="flex flex-wrap gap-2">
          <% @pet.conditions.each do |c| %>
            <div class="text-xs bg-error-container text-red-800 px-3 py-1 rounded-full">
              <%= c.name %><%= " — #{c.dietary_notes}" if c.dietary_notes.present? %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Custom notes (if present) -->
  <% if @prescription.respond_to?(:custom_allergens_notes) && @prescription.custom_allergens_notes.present? %>
    <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 mb-6">
      <p class="text-xs font-semibold text-amber-800 uppercase tracking-wide mb-1">Notas sobre alérgenos</p>
      <p class="text-sm text-amber-900"><%= @prescription.custom_allergens_notes %></p>
    </div>
  <% end %>
  <% if @prescription.respond_to?(:custom_conditions_notes) && @prescription.custom_conditions_notes.present? %>
    <div class="bg-blue-50 border border-blue-200 rounded-2xl p-5 mb-6">
      <p class="text-xs font-semibold text-blue-800 uppercase tracking-wide mb-1">Notas sobre condiciones</p>
      <p class="text-sm text-blue-900"><%= @prescription.custom_conditions_notes %></p>
    </div>
  <% end %>

  <!-- Rejected recipes (audit) -->
  <% if @prescription.rejected_recipes.any? %>
    <div class="bg-white rounded-2xl border border-outline-variant shadow-sm mb-6 p-6">
      <h2 class="text-sm font-bold text-on-surface-variant mb-3 uppercase tracking-wide">Recetas descartadas</h2>
      <ul class="space-y-1">
        <% @prescription.rejected_recipes.each do |r| %>
          <li class="text-xs text-on-surface-variant">
            <span class="font-medium text-on-background"><%= r["recipe_name"] %></span>
            — <%= r["reason"] %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Actions -->
  <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
    <%= button_to upvote_pet_diet_prescription_path(@pet, @prescription),
          method: :post,
          class: "inline-flex items-center gap-2 bg-secondary-container text-on-secondary-container text-sm font-semibold px-6 py-3 rounded-xl hover:opacity-90 transition-opacity" do %>
      <span class="material-symbols-outlined text-base leading-none">thumb_up</span>
      Esta dieta funciona bien
      <% if @prescription.upvotes_count > 0 %>
        <span class="bg-white/40 rounded-full text-xs px-2 py-0.5 ml-1"><%= @prescription.upvotes_count %></span>
      <% end %>
    <% end %>

    <!-- Regenerate with optional standard override -->
    <div class="flex flex-col items-center gap-1">
      <%= button_to regenerate_pet_diet_prescription_path(@pet, @prescription),
            method: :post,
            params: {
              diet_type:         @prescription.try(:diet_type),
              preparation_style: @prescription.try(:preparation_style),
              standard_name:     @prescription.try(:standard_override)
            },
            class: "inline-flex items-center gap-2 bg-secondary text-white text-sm font-semibold px-6 py-3 rounded-xl hover:opacity-90 transition-opacity" do %>
        <span class="material-symbols-outlined text-base leading-none">refresh</span>
        Regenerar con IA
      <% end %>
      <!-- Standard override links — only shown as secondary option -->
      <div class="flex items-center gap-1 text-xs text-on-surface-variant mt-0.5">
        <span>Cambiar estándar:</span>
        <% std_urls = { "AAFCO" => "https://www.aafco.org/", "FEDIAF" => "https://europeanpetfood.org/", "NRC" => "https://nap.nationalacademies.org/" } %>
        <% [["AAFCO", "2023"], ["FEDIAF", "2023"], ["NRC", "2006"]].each do |std, ver| %>
          <%
            is_current = @prescription.nutritional_standard.standard_name == std
            regen_url  = regenerate_pet_diet_prescription_path(@pet, @prescription)
          %>
          <%= button_to regen_url,
                method: :post,
                params: { diet_type: @prescription.try(:diet_type), preparation_style: @prescription.try(:preparation_style), standard_name: std },
                class: "#{is_current ? 'font-bold text-primary' : 'hover:underline'} inline-flex items-center gap-0.5" do %>
            <%= std %>
            <a href="<%= std_urls[std] %>" target="_blank" rel="noopener noreferrer"
               onclick="event.stopPropagation();"
               class="material-symbols-outlined text-xs leading-none opacity-50 hover:opacity-100">open_in_new</a>
          <% end %>
          <% unless std == "NRC" %><span class="opacity-30">·</span><% end %>
        <% end %>
      </div>
    </div>

    <%= link_to new_pet_diet_prescription_path(@pet),
          class: "inline-flex items-center gap-2 border border-outline-variant text-on-surface-variant text-sm font-semibold px-6 py-3 rounded-xl hover:bg-surface-low transition-colors" do %>
      <span class="material-symbols-outlined text-base leading-none">swap_horiz</span>
      Ver otras propuestas
    <% end %>
  </div>
</div>
