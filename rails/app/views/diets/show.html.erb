<% content_for :title, "Plan de #{@pet.name}" %>
<% content_for :title, t("diets.show.page_title", pet_name: @pet.name) %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <%= link_to t("diets.show.back_link", pet_name: @pet.name), @pet, class: "text-sm text-primary font-medium hover:underline block mb-6" %>

  <% plan = @fixed_set_plan || {} %>
  <% recipes = @plan_recipes || [] %>
  <% report = @validation_report || {} %>
  <% premix = plan["premix"] || {} %>
  <% plan_status = if premix.present? && premix["mandatory"]
    t("diets.show.status.needs_premix")
  elsif report["valid"] == false
    t("diets.show.status.needs_review")
  else
    t("diets.show.status.validated")
  end %>

  <div class="bg-white rounded-2xl border border-outline-variant shadow-sm overflow-hidden mb-6">
    <div class="h-2 bg-primary"></div>
    <div class="p-6">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h1 class="text-xl font-bold text-on-background">Plan nutricional de <%= @pet.name %></h1>
          <p class="text-on-surface-variant text-sm mt-0.5">
            <%= @pet.weight_kg %> kg · <%= @pet.life_stage_label %> · <%= @pet.activity_label %>
            <% if @pet.is_neutered %> · Esterilizado/a<% end %>
          </p>
        </div>
        <div class="flex flex-col items-end gap-1">
          <% mode_value = (plan["diet_mode"].presence || @diet.preparation_style).to_s %>
          <% mode_label = Diet::PREP_STYLES.fetch(mode_value, mode_value.humanize) %>
          <span class="inline-block text-xs font-semibold bg-primary/10 text-primary px-3 py-1 rounded-full whitespace-nowrap">
            <%= mode_label %>
          </span>
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
        <div class="bg-surface-low rounded-xl px-3 py-3 text-center">
          <span class="block font-bold text-on-background text-2xl"><%= (plan["recipe_count"] || recipes.size).to_i %></span>
          <span class="text-on-surface-variant text-xs font-medium">días del plan</span>
        </div>
        <div class="bg-surface-low rounded-xl px-3 py-3 text-center">
          <% total_kcal = plan["total_kcal_set"].to_f.positive? ? plan["total_kcal_set"].to_f : recipes.sum { |recipe| recipe["kcal_target"].to_f } %>
          <span class="block font-bold text-on-background text-2xl"><%= total_kcal.round(0) %> <span class="text-base font-semibold">kcal</span></span>
          <span class="text-on-surface-variant text-xs font-medium">total del set</span>
        </div>
        <div class="bg-surface-low rounded-xl px-3 py-3 text-center">
          <span class="block font-bold text-on-background text-2xl"><%= (plan["kcal_per_recipe"] || @diet.der_kcal).to_f.round(0) %> <span class="text-base font-semibold">kcal</span></span>
          <span class="text-on-surface-variant text-xs font-medium">por día</span>
        </div>
        <div class="bg-surface-low rounded-xl px-3 py-3 text-center">
        <% status_color = plan_status == t("diets.show.status.validated") ? 'text-green-700' : 'text-amber-700' %>
          <span class="block font-bold text-2xl <%= status_color %>">
            <%= plan_status %>
          </span>
          <span class="text-on-surface-variant text-xs font-medium">estado nutricional</span>
        </div>
      </div>

      <p class="mt-4 text-xs text-on-surface-variant">
      <%= t("diets.show.plan_note") %>
      </p>

      <% if @bcs_warning.present? %>
        <div class="mt-4 text-xs <%= @bcs_critical ? 'text-red-700 bg-red-50 border-red-300' : 'text-amber-700 bg-amber-50 border-amber-200' %> border rounded-xl px-3 py-2 leading-relaxed">
          <%= @bcs_warning %>
        </div>
      <% end %>
    </div>
  </div>

  <% failures = Array(report["failures"]) %>
  <% if failures.any? %>
    <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 mb-6">
      <h2 class="font-bold text-amber-900 mb-2"><%= t("diets.show.validator.heading") %></h2>
      <ul class="space-y-1 text-sm text-amber-800">
        <% failures.each do |failure| %>
          <li>• <%= failure %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if premix.present? && premix["mandatory"] %>
    <% premix_labels = {
      "calcium_mg" => t("diets.show.nutrients.calcium"),
      "phosphorus_mg" => t("diets.show.nutrients.phosphorus"),
      "magnesium_mg" => t("diets.show.nutrients.magnesium"),
      "potassium_mg" => t("diets.show.nutrients.potassium"),
      "zinc_mg" => t("diets.show.nutrients.zinc"),
      "iron_mg" => t("diets.show.nutrients.iron"),
      "copper_mg" => t("diets.show.nutrients.copper"),
      "iodine_mcg" => t("diets.show.nutrients.iodine"),
      "selenium_mcg" => t("diets.show.nutrients.selenium")
    } %>
    <div class="bg-blue-50 border border-blue-200 rounded-2xl p-5 mb-6">
      <h2 class="font-bold text-blue-900 mb-1"><%= t("diets.show.premix.heading", name: premix["name"].presence || t("diets.show.premix.default_name")) %></h2>
      <p class="text-sm text-blue-800 mb-3"><%= premix["note"].presence || t("diets.show.premix.default_note") %></p>
      <% if premix["description"].present? %>
        <p class="text-sm text-blue-800 mb-2"><%= premix["description"] %></p>
      <% end %>
      <% if premix["grams_per_day"].to_f.positive? %>
        <p class="text-sm text-blue-900 font-semibold mb-3"><%= premix["grams_per_day"].to_f.round(2) %> g/día recomendados</p>
      <% end %>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-xs text-blue-900">
        <% (premix["payload"] || {}).each do |k, v| %>
          <% key = k.to_s %>
          <% label = premix_labels[key] || key.humanize %>
          <% unit = key.end_with?("_mcg") ? "mcg" : "mg" %>
          <% amount = v.to_f.round(2) %>
          <% next if amount <= 0 %>
          <div class="bg-white/70 rounded-lg px-2 py-1">
            <span class="font-semibold"><%= label %>:</span> <%= amount %> <%= unit %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl border border-outline-variant shadow-sm p-6 mb-6">
    <h2 class="font-bold text-on-background mb-2"><%= t("diets.show.days.heading") %></h2>
    <p class="text-sm text-on-surface-variant mb-4"><%= t("diets.show.days.description") %></p>
    <% category_labels = {
      "protein" => t("diets.show.categories.protein"),
      "vegetable" => t("diets.show.categories.vegetable"),
      "carb" => t("diets.show.categories.carb"),
      "fat" => t("diets.show.categories.fat")
    } %>

    <div class="space-y-4">
      <% recipes.each_with_index do |recipe, idx| %>
        <div class="border border-outline-variant rounded-xl p-4">
          <div class="flex items-center justify-between gap-3 mb-3">
            <h3 class="font-semibold text-on-background"><%= recipe["name"].presence || t("diets.show.days.day_label", number: idx + 1) %></h3>
            <span class="text-xs font-semibold bg-primary/10 text-primary px-2 py-1 rounded-full"><%= recipe["kcal_target"].to_f.round(0) %> kcal</span>
          </div>

          <div class="space-y-2">
            <% Array(recipe["items"]).each do |item| %>
              <div class="flex items-center justify-between text-sm bg-surface-low rounded-lg px-3 py-2">
                <div>
                  <span class="font-medium text-on-background"><%= item["ingredient_name"] %></span>
                  <span class="text-xs text-on-surface-variant"> · <%= category_labels[item["category"].to_s] || item["category"].to_s.humanize %></span>
                </div>
                <span class="text-on-surface-variant"><%= item["daily_amount_g"].to_f.round(1) %> g</span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <% if @bcs_critical %>
    <div class="bg-red-50 border border-red-300 rounded-2xl shadow-sm p-6 mb-6">
      <h2 class="font-bold text-red-900 mb-2"><%= t("diets.show.critical.heading") %></h2>
      <p class="text-sm text-red-800 leading-relaxed">
        <%= t("diets.show.critical.body", bcs: @pet.body_condition_score) %>
      </p>
    </div>
  <% else %>
    <div class="bg-white rounded-2xl border border-outline-variant shadow-sm p-6">
      <h2 class="font-bold text-on-background mb-1"><%= t("diets.show.regenerate.heading") %></h2>
      <p class="text-sm text-on-surface-variant mb-4">
        <%= t("diets.show.regenerate.description") %>
      </p>

      <%= form_with url: regenerate_pet_diet_path(@pet, @diet), method: :patch, local: true, class: "space-y-4" do |f| %>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1"><%= t("diets.show.regenerate.plan_mode") %></label>
          <% selected_mode = (plan["diet_mode"].presence || @diet.preparation_style).to_s %>
          <select name="diet_mode" class="w-full text-sm border border-outline-variant rounded-lg px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-primary">
            <option value="cooked" <%= "selected" if selected_mode == "cooked" %>><%= t("diets.show.modes.cooked") %></option>
            <option value="mixed" <%= "selected" if selected_mode == "mixed" %>><%= t("diets.show.modes.mixed") %></option>
            <option value="raw" <%= "selected" if selected_mode == "raw" %>><%= Diet::PREP_STYLES["raw"] %></option>
          </select>
        </div>

        <button type="submit" class="bg-primary text-white text-sm font-semibold px-6 py-2.5 rounded-xl hover:opacity-90 transition-opacity">
          <%= t("diets.show.regenerate.button") %>
        </button>
      <% end %>
    </div>
  <% end %>
</div>
