<!DOCTYPE html>

<html class="light" lang="es"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">tailwind.config = {darkMode: "class", theme: {extend: {colors: {primary: "#005d90", "on-primary": "#ffffff", "primary-container": "#0077b6", "on-primary-container": "#f3f7ff", secondary: "#00677d", "on-secondary": "#ffffff", "secondary-container": "#50d9fe", "on-secondary-container": "#005c70", tertiary: "#00626f", "on-tertiary": "#ffffff", "tertiary-container": "#227c8a", "on-tertiary-container": "#e7fbff", error: "#ba1a1a", "on-error": "#ffffff", "error-container": "#ffdad6", "on-error-container": "#93000a", background: "#eefcff", "on-background": "#001f24", surface: "#eefcff", "on-surface": "#001f24", "surface-variant": "#c3e9f1", "on-surface-variant": "#404850", outline: "#707881", "outline-variant": "#bfc7d1", "surface-container-lowest": "#ffffff", "surface-container-low": "#dcf9ff", "surface-container": "#cef5fd", "surface-container-high": "#c9eff7", "surface-container-highest": "#c3e9f1", "primary-fixed-dim": "#94ccff", "on-tertiary-fixed-variant": "#004f59", "inverse-surface": "#0e353c", "secondary-fixed-dim": "#4cd6fb", "surface-tint": "#006399", "on-tertiary-fixed": "#001f24", "on-secondary-fixed": "#001f27", "on-primary-fixed": "#004b74", "primary-fixed": "#cde5ff", "inverse-on-surface": "#d2f7ff", "surface-bright": "#eefcff", "on-primary-fixed-variant": "#004b74", "primary-fixed": "#cde5ff", "inverse-primary": "#94ccff", "tertiary-fixed": "#9feffe", "surface-dim": "#bbe1e8", "tertiary-fixed-dim": "#83d3e1", "on-secondary-fixed-variant": "#004e5f"}, borderRadius: {DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px"}, fontFamily: {headline: ["Plus Jakarta Sans"], body: ["Plus Jakarta Sans"], label: ["Plus Jakarta Sans"], display: "Plus Jakarta Sans"}}}};</script>
<style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-nav { background: rgba(248, 250, 253, 0.6); backdrop-filter: blur(12px); }
        .restorative-mesh {
            background-image: radial-gradient(at 0% 0%, #B0C4DE 0%, transparent 50%), radial-gradient(at 100% 100%, #d6e4f0 0%, transparent 50%);
            opacity: 0.3;
        }
    </style>
</head>
<body class="bg-surface text-on-surface antialiased">
<%= render 'shared/navbar' %>
<main class="relative pt-16 overflow-hidden">
<div class="absolute inset-0 restorative-mesh -z-10"></div>
<!-- Hero Section -->
<section class="relative px-6 py-16 lg:py-24 max-w-screen-2xl mx-auto">
<div class="grid lg:grid-cols-2 gap-12 items-center">
<div class="order-2 lg:order-1">
<span class="inline-flex items-center px-4 py-1.5 rounded-full bg-secondary-container text-on-secondary-container text-xs font-bold font-label uppercase tracking-widest mb-6">
                    MVP MÉXICO 2024
                </span>
<h1 class="text-5xl lg:text-7xl font-extrabold font-headline text-on-surface tracking-tighter leading-[1.1] mb-6">
                    Nutrición Veterinaria de <span class="text-primary">Precisión</span>
</h1>
<p class="text-xl text-on-surface-variant font-body leading-relaxed mb-10 max-w-xl">
                    Recetas seguras validadas por expertos. Diseñamos planes de alimentación clínica que transforman la salud de tu mascota con rigor científico.
                </p>
<div class="flex flex-col sm:flex-row gap-4">
<button class="bg-primary text-on-primary px-8 py-4 rounded-full text-lg font-bold shadow-sm hover:opacity-90 active:scale-95 transition-all flex items-center justify-center gap-2">
                        Comenzar Plan Gratuito
                        <span class="material-symbols-outlined">arrow_forward</span>
</button>
<button class="bg-surface-container-highest text-on-surface-variant px-8 py-4 rounded-full text-lg font-bold hover:bg-surface-container-high transition-colors">
                        Ver Metodología
                    </button>
</div>
<div class="mt-8 flex items-center gap-4">
<div class="flex -space-x-3">
<img alt="profile" class="w-10 h-10 rounded-full border-2 border-white object-cover" src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&h=100&q=80"/>
<img alt="profile" class="w-10 h-10 rounded-full border-2 border-white object-cover" src="https://images.unsplash.com/photo-1494790108755-2616b612b786?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&h=100&q=80"/>
<img alt="profile" class="w-10 h-10 rounded-full border-2 border-white object-cover" src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&h=100&q=80"/>
</div>
<p class="text-sm font-label text-on-surface-variant">
<span class="font-bold text-primary">+500 Vets</span> en México ya confían en NutriVet.
                    </p>
</div>
</div>
<div class="order-1 lg:order-2 relative">
<div class="aspect-square relative rounded-[3rem] overflow-hidden shadow-xl shadow-primary-container">
<img alt="veterinarian with dog" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC5qhcb6Lio4rDmik4BKG9gdNO7annZl-fZdpq4YD1JIZA5C-ODGNqPg3zxpORBR3TkRxwvdnMKc9JY8xzOQ-yNZo3xlFC4GzS7PAoydSz03QQQH2TRZ0KtAhXgxCVUxmUQRL_WooOGOkNX_OjC7LsPQ5HYVdRd5PlRizCMh7Ztafj0_GiBl6MhzuaVYOMZdSsBxM2z6rBEBItG0Cdjtadtm3su9FureL8ZTpy4IMzL4F5xwrEhKirKoxqm4MpCWL3jatgj_Q-9JuM"/>
<div class="absolute inset-0 bg-gradient-to-t from-primary-container/30 to-transparent"></div>
</div>
<!-- Floating Data Card -->
<div class="absolute -bottom-6 -left-6 bg-white/90 backdrop-blur-xl p-6 rounded-3xl shadow-lg border border-white/50 max-w-[240px]">
<div class="flex items-center gap-3 mb-2">
<div class="bg-primary-container p-2 rounded-full">
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">science</span>
</div>
<span class="font-bold text-primary font-headline">Fórmulas WSAVA</span>
</div>
<div class="h-2 w-full bg-surface-container rounded-full overflow-hidden">
<div class="h-full bg-primary w-[94%]"></div>
</div>
<p class="text-[10px] font-label text-on-surface-variant mt-2 tracking-tight">CUMPLIMIENTO ESTRICTO DE ESTÁNDARES INTERNACIONALES</p>
</div>
</div>
</div>
</section>
<!-- Features Bento Grid -->
<section class="px-6 py-20 bg-surface-container-low">
<div class="max-w-screen-2xl mx-auto">
<div class="text-center mb-16">
<h2 class="text-3xl lg:text-5xl font-extrabold font-headline mb-4 tracking-tight">Ciencia aplicada al plato</h2>
<p class="text-on-surface-variant max-w-2xl mx-auto">Nuestro sistema integra las normativas más estrictas para garantizar una vida larga y saludable.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<!-- Feature 1 -->
<div class="bg-surface-container-lowest p-10 rounded-[2.5rem] flex flex-col items-start gap-6 hover:shadow-md transition-all duration-300">
<div class="w-14 h-14 bg-primary-container flex items-center justify-center rounded-full">
<span class="material-symbols-outlined text-primary scale-125">verified_user</span>
</div>
<h3 class="text-2xl font-bold font-headline">Fórmulas WSAVA</h3>
<p class="text-on-surface-variant leading-relaxed">Lineamientos globales de la World Small Animal Veterinary Association integrados en cada cálculo calórico.</p>
<div class="mt-auto w-full pt-6 border-t border-surface-container">
<span class="text-xs font-bold font-label uppercase text-primary">Estándar Oro</span>
</div>
</div>
<!-- Feature 2 -->
<div class="bg-primary p-10 rounded-[2.5rem] text-on-primary flex flex-col items-start gap-6 relative overflow-hidden group">
<div class="absolute top-0 right-0 p-12 opacity-10 scale-[2.5] rotate-12 group-hover:rotate-0 transition-transform duration-700">
<span class="material-symbols-outlined text-[100px]">local_mall</span>
</div>
<div class="w-14 h-14 bg-white/20 flex items-center justify-center rounded-full">
<span class="material-symbols-outlined text-white scale-125">eco</span>
</div>
<h3 class="text-2xl font-bold font-headline text-white">Ingredientes Locales</h3>
<p class="text-white/80 leading-relaxed">Adaptamos las dietas a los insumos disponibles en el mercado mexicano, garantizando frescura y accesibilidad.</p>
<div class="mt-auto w-full pt-6 border-t border-white/10">
<span class="text-xs font-bold font-label uppercase">Mercado Nacional</span>
</div>
</div>
<!-- Feature 3 -->
<div class="bg-surface-container-lowest p-10 rounded-[2.5rem] flex flex-col items-start gap-6 hover:shadow-md transition-all duration-300">
<div class="w-14 h-14 bg-secondary-container flex items-center justify-center rounded-full">
<span class="material-symbols-outlined text-on-secondary-container scale-125">medical_services</span>
</div>
<h3 class="text-2xl font-bold font-headline">Supervisión Médica</h3>
<p class="text-on-surface-variant leading-relaxed">Cada plan es revisado por veterinarios titulados bajo las normas de SADER y la NOM-012.</p>
<div class="mt-auto w-full pt-6 border-t border-surface-container">
<span class="text-xs font-bold font-label uppercase text-secondary">Validación Directa</span>
</div>
</div>
</div>
</div>
</section>
<!-- Social Proof / Associations -->
<section class="py-24 px-6">
<div class="max-w-screen-2xl mx-auto text-center">
<p class="text-sm font-label font-bold text-outline uppercase tracking-widest mb-12">Respaldado por instituciones líderes</p>
<div class="flex flex-wrap justify-center items-center gap-12 lg:gap-24 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500">
<div class="flex flex-col items-center gap-2">
<span class="material-symbols-outlined text-5xl">apartment</span>
<span class="font-headline font-bold text-xl">AMMVEPE</span>
</div>
<div class="flex flex-col items-center gap-2">
<span class="material-symbols-outlined text-5xl">health_and_safety</span>
<span class="font-headline font-bold text-xl">COMVET</span>
</div>
<div class="flex flex-col items-center gap-2">
<span class="material-symbols-outlined text-5xl">account_balance</span>
<span class="font-headline font-bold text-xl">SADER</span>
</div>
<div class="flex flex-col items-center gap-2">
<span class="material-symbols-outlined text-5xl">verified</span>
<span class="font-headline font-bold text-xl">FEDMVZ</span>
</div>
</div>
</div>
</section>
<!-- Final CTA -->
<section class="px-6 py-20 lg:py-32">
<div class="max-w-4xl mx-auto bg-surface-container-highest rounded-[4rem] p-12 lg:p-20 text-center relative overflow-hidden">
<div class="absolute inset-0 bg-gradient-to-br from-primary-container/20 to-secondary-container/20"></div>
<div class="relative z-10">
<h2 class="text-4xl lg:text-6xl font-extrabold font-headline mb-8 tracking-tighter text-on-surface">¿Listo para mejorar la vida de tu paciente?</h2>
<p class="text-xl text-on-surface-variant mb-12 max-w-xl mx-auto">Únete a la plataforma que está digitalizando la nutrición clínica en México.</p>
<button class="bg-primary text-on-primary px-12 py-5 rounded-full text-xl font-bold shadow-lg shadow-primary/20 hover:scale-105 active:scale-95 transition-all">
                    Comenzar Plan Gratuito
                </button>
<p class="mt-6 text-sm text-outline font-label">Sin tarjeta de crédito. Configuración en 2 minutos.</p>
</div>
</div>
</section>
</main>
<!-- Footer (Shared Component Footer COMPONENTS_53) -->
<footer class="w-full py-12 px-8 border-t border-slate-200/50 dark:border-slate-800/50 bg-slate-100 dark:bg-slate-950">
<div class="flex flex-col md:flex-row justify-between items-center gap-4 max-w-screen-2xl mx-auto">
<div class="mb-4 md:mb-0">
<p class="font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-widest text-slate-500">
                © 2024 NutriPet Mexico. Cumplimiento con NOM-012-SAG/ZOO-2020 y regulaciones de SADER.
            </p>
</div>
<div class="flex flex-wrap justify-center gap-8 font-['Plus_Jakarta_Sans'] text-xs uppercase tracking-widest">
<a class="text-slate-500 hover:text-blue-600 transition-colors" href="#">Política de Privacidad</a>
<a class="text-slate-500 hover:text-blue-600 transition-colors" href="#">Términos de Servicio</a>
<a class="text-slate-500 hover:text-blue-600 transition-colors" href="#">Guías SAGARPA</a>
<a class="text-slate-500 hover:text-blue-600 transition-colors" href="#">Contacto</a>
</div>
</div>
</footer>
</body></html>
