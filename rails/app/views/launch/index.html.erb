    <script>
        // --- 1. ROTACIÓN DE TEXTOS DEL HERO ---
        const badgeData = [
            "Sistema de Calificaciones para Arrendamientos",
            "Historial de Comportamiento en Rentas",
            "Red de Confianza para Arrendar",
            "Protección para Arrendadores e Arrendatarios"
        ];

        const slogans1 = [
            "Consulta el historial de",
            "Verifica el comportamiento de",
            "Conoce la reputación de",
            "Revisa las calificaciones de"
        ];

        const slogans2 = [
            "cualquier arrendatario",
            "cualquier arrendador",
            "cualquier inquilino",
            "tus prospectos",
            "tu casero",
            "tu roomie",
            "futuros inquilinos",
            "cada candidato"
        ];

        async function rotateHeroTexts() {
            const badge = document.getElementById('hero-badge');
            const s1 = document.getElementById('slogan1');
            const s2 = document.getElementById('slogan2');

            // Fade out
            [badge, s1, s2].forEach(el => el.classList.add('is-hidden'));
            await new Promise(r => setTimeout(r, 800));

            // Update texts
            document.getElementById('badgeText').innerText = badgeData[Math.floor(Math.random() * badgeData.length)];
            s1.innerText = slogans1[Math.floor(Math.random() * slogans1.length)];
            s2.innerText = slogans2[Math.floor(Math.random() * slogans2.length)];

            // Fade in
            [badge, s1, s2].forEach(el => el.classList.remove('is-hidden'));
        }

        // --- 2. MONITOR DE SEGURIDAD DINÁMICO (LÁSER + PALOMITAS) ---
        const featurePool = [
            ["Cuentas verificadas", "Relación Contractual Validada", "Cifrado de Grado Militar"],
            ["Identidad Protegida", "Respaldo legal", "Auditoría en Tiempo Real"],
            ["Cero Suplantación", "Historial Verificado", "Base de Datos Global"],
            ["Validación Activa", "Red de Confianza", "Protección Total"]
        ];
        let fSetIndex = 0;

        function refreshMonitor() {
            const box = document.getElementById('featureList');
            const set = featurePool[fSetIndex];
            box.innerHTML = set.map((f, i) => `
                <div class="feat-item flex items-center justify-between text-xs font-extrabold uppercase tracking-widest" id="f-${i}">
                    <span>${f}</span>
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
            `).join('');

            // Sincronizar palomitas con la barra láser
            setTimeout(() => document.getElementById('f-0').classList.add('active'), 1000);
            setTimeout(() => document.getElementById('f-1').classList.add('active'), 2000);
            setTimeout(() => document.getElementById('f-2').classList.add('active'), 3000);

            fSetIndex = (fSetIndex + 1) % featurePool.length;
        }

        // --- 3. FUNCIONES CORE ---
        function scrollToId(id) { document.getElementById(id).scrollIntoView({ behavior: 'smooth' }); }

        function handleKeyPress(event) {
            if (event.key === 'Enter') {
                openMockup();
            }
        }

        function openMockup() {
            const input = document.getElementById('searchInput');
            const inputMobile = document.getElementById('searchInputMobile');
            const value = input ? input.value.trim() : inputMobile.value.trim();
            if (value !== "") document.getElementById('demoName').innerText = value;
            document.getElementById('mockupModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
        function closeModal() {
            document.getElementById('mockupModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
            const input = document.getElementById('searchInput');
            const inputMobile = document.getElementById('searchInputMobile');
            if (input) input.value = "";
            if (inputMobile) inputMobile.value = "";
        }

        window.onload = () => {
            // Iniciar rotación de hero
            setInterval(rotateHeroTexts, 8000);

            // Iniciar Monitor
            refreshMonitor();
            setInterval(refreshMonitor, 4000);

            // Iniciar Carrusel
            const risks = [
                { i: "fa-user-xmark", t: "Eliminar la Morosidad Crónica", d: "Inquilinos que acumulan meses de impagos, generando pérdidas acumuladas y procesos legales costosos." },
                { i: "fa-house-circle-exclamation", t: "Detener las Rentas Fantasma", d: "Estafas donde propietarios inexistentes cobran depósitos y desaparecen, dejando inquilinos sin hogar." },
                { i: "fa-clock-rotate-left", t: "Evitar Juicios Innecesarios", d: "Desalojos que toman hasta 24 meses en tribunales saturados, con costos elevados y propiedades ociosas." },
                { i: "fa-user-lock", t: "Prevenir la Suplantación de Identidad", d: "Delincuentes que usan documentos falsos para rentar, causando daños y dificultades de identificación." },
                { i: "fa-hand-holding-dollar", t: "Parar los Fraudes Financieros", d: "Propietarios que cobran pero no reparan ni mantienen, o desaparecen con el dinero." },
                { i: "fa-money-bill-wave", t: "Reducir Pérdidas Económicas Masivas", d: "Daños por impagos, vandalismo, desgaste acelerado y oportunidades perdidas de alquiler." },
                { i: "fa-chart-line", t: "Mejorar las Estadísticas de Impago", d: "Hasta el 30% de contratos terminan en morosidad, con promedio de 3-6 meses de impagos." },
                { i: "fa-gavel", t: "Evitar Problemas Legales", d: "Contratos fraudulentos derivan en estafa, falsificación y lavado de dinero organizado." },
                { i: "fa-user-secret", t: "Evitar Investigadores Privados Costosos", d: "Investigadores privados con cobros excesivos que complican procesos sin resultados garantizados." },
                { i: "fa-user-times", t: "Evitar Inquilinos Problemáticos", d: "Inquilinos que causan daños a la propiedad, generan conflictos, ruido excesivo o abandonan sin previo aviso." }
            ];
            const track = document.getElementById('riskTrack');
            const items = [...risks, ...risks, ...risks];
            track.innerHTML = items.map(r => `
                <div class="risk-card">
                    <i class="fa-solid ${r.i} text-emerald-600 text-2xl mb-6"></i>
                    <h4 class="font-extrabold text-[#021017] text-[10px] uppercase mb-3 tracking-widest">${r.t}</h4>
                    <p class="text-[11px] text-slate-500 italic leading-relaxed font-medium">${r.d}</p>
                </div>
            `).join('');
        };

        window.onclick = e => { if(e.target.id == 'mockupModal') closeModal(); }

        // --- 4. SUCCESS MESSAGE HANDLER ---
        document.addEventListener("DOMContentLoaded", function() {
            const form = document.getElementById('preRegForm');
            if (!form) return;

            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const formData = new FormData(form);
                const messageDiv = document.getElementById('formMessage');
                const submitBtn = form.querySelector('input[type="submit"]');

                // UI Reset
                messageDiv.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-emerald-600"></i> Procesando...';
                messageDiv.className = 'text-sm text-center text-slate-500 italic mt-4';
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-50', 'cursor-not-allowed');

                try {
                    // Force JSON response
                    const response = await fetch(form.action + ".json", {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
                        }
                    });

                    const data = await response.json();

                    if (response.ok || response.status === 201) {
                         // Success - Clear form and show message
                         form.reset();
                         messageDiv.innerHTML = `
                            <div class="flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-700 p-4 rounded-xl text-left shadow-sm animate-fade-in-up">
                                <div class="bg-emerald-100 p-2 rounded-full"><i class="fa-solid fa-check text-emerald-600"></i></div>
                                <div>
                                    <p class="font-bold text-xs uppercase tracking-widest">¡Registro Exitoso!</p>
                                    <p class="text-[10px] opacity-80 mt-1">Gracias por unirte al acceso anticipado. Tu registro ha sido guardado exitosamente.</p>
                                </div>
                            </div>
                         `;
                         messageDiv.className = 'mt-6 mb-2';

                         // Re-enable button
                         submitBtn.disabled = false;
                         submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');

                         // Auto-hide message after 5 seconds
                         setTimeout(() => {
                             if(messageDiv.innerHTML.includes('Registro Exitoso')) {
                                 messageDiv.innerHTML = '';
                                 messageDiv.className = 'text-sm text-center text-slate-500 italic';
                             }
                         }, 5000);

                    } else {
                        // Error handling
                        let errorMsg = 'Ocurrió un error inesperado.';

                        if (data.errors) {
                             // Format specific field errors
                             let messages = [];
                             // Map technical field names to Spanish labels
                             const fieldMap = {
                                 'email': 'Correo electrónico',
                                 'first_name': 'Nombre',
                             };

                             for (const [key, value] of Object.entries(data.errors)) {
                                 // Get friendly name or capitalize
                                 const label = fieldMap[key] || key.charAt(0).toUpperCase() + key.slice(1);
                                 // Deduplicate identical messages for same field
                                 const uniqueMsgs = [...new Set(value)];

                                 uniqueMsgs.forEach(msg => messages.push(`${label} ${msg}`));
                             }
                             errorMsg = messages.join('. ');
                        } else if (data.error) {
                             errorMsg = data.error;
                        }

                        messageDiv.innerHTML = `<i class="fa-solid fa-circle-exclamation text-red-500 mr-2"></i> ${errorMsg}`;
                        messageDiv.className = 'text-sm text-center text-red-600 font-bold bg-red-50 p-3 rounded-lg mt-4 border border-red-100';
                        submitBtn.disabled = false;
                        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                    }

                } catch (error) {
                    console.error('Submission error:', error);
                    messageDiv.innerHTML = '<i class="fa-solid fa-wifi text-red-500 mr-2"></i> Error de conexión. Intente nuevamente.';
                     messageDiv.className = 'text-sm text-center text-red-600 font-bold bg-red-50 p-3 rounded-lg mt-4 border border-red-100';
                    submitBtn.disabled = false;
                     submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                }
            });
        });
    </script>

    <!-- Mobile Menu Toggle Script -->
    <script>
        function closeMobileMenu() {
            const mobileMenu = document.getElementById('mobileMenu');
            if (mobileMenu) {
                mobileMenu.classList.add('hidden');
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const mobileMenu = document.getElementById('mobileMenu');

            if (mobileMenuBtn && mobileMenu) {
                mobileMenuBtn.addEventListener('click', function() {
                    mobileMenu.classList.toggle('hidden');
                });

                // Close menu when clicking outside
                document.addEventListener('click', function(event) {
                    if (!mobileMenuBtn.contains(event.target) && !mobileMenu.contains(event.target)) {
                        mobileMenu.classList.add('hidden');
                    }
                });
            }
        });
    </script>
</body>
</html>
