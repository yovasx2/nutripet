<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) + " · NutriPet" : "NutriPet" %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005d90",
            "on-primary": "#ffffff",
            "primary-container": "#0077b6",
            "on-primary-container": "#f3f7ff",
            secondary: "#00677d",
            "secondary-container": "#50d9fe",
            "on-secondary-container": "#005c70",
            background: "#eefcff",
            "on-background": "#001f24",
            surface: "#eefcff",
            "on-surface": "#001f24",
            "surface-variant": "#c3e9f1",
            "on-surface-variant": "#404850",
            "surface-low": "#dcf9ff",
            "surface-container": "#cef5fd",
            "surface-high": "#c9eff7",
            "surface-highest": "#c3e9f1",
            outline: "#707881",
            "outline-variant": "#bfc7d1",
            error: "#ba1a1a",
            "error-container": "#ffdad6",
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          fontFamily: {
            sans: ["Plus Jakarta Sans", "Inter", "sans-serif"]
          }
        }
      }
    }
  </script>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <script src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8/dist/turbo.es2017.umd.js"></script>
</head>
<body class="bg-background text-on-background font-sans antialiased min-h-screen">
  <%= render "shared/navbar" %>

  <% if notice.present? %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 bg-secondary-container text-on-secondary-container text-sm font-medium px-5 py-3 rounded-xl shadow-lg" id="flash-notice">
      <%= notice %>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 bg-error-container text-red-800 text-sm font-medium px-5 py-3 rounded-xl shadow-lg" id="flash-alert">
      <%= alert %>
    </div>
  <% end %>

  <main class="pt-20">
    <%= yield %>
  </main>

  <script>
    // Auto-dismiss flash messages after 4s
    setTimeout(() => {
      ["flash-notice", "flash-alert"].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.remove();
      });
    }, 4000);
  </script>
</body>
</html>
