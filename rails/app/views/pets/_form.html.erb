<!-- Shared form partial for new + edit pet -->
<%= form_with model: pet, class: "space-y-6" do |f| %>
  <% if pet.errors.any? %>
    <div class="bg-error-container text-red-800 text-sm rounded-xl px-4 py-3">
      <ul class="list-disc list-inside space-y-1">
        <% pet.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <!-- Name -->
    <div>
      <%= f.label :name, "Nombre", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.text_field :name, class: "w-full border border-outline-variant rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-white", placeholder: "Ej. Luna" %>
    </div>

    <!-- Breed -->
    <div>
      <%= f.label :breed, "Raza", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.text_field :breed, class: "w-full border border-outline-variant rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-white", placeholder: "Ej. Labrador" %>
    </div>

    <!-- Species -->
    <div>
      <%= f.label :species, "Especie", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.select :species, Pet::SPECIES.map { |s| [s.capitalize, s] },
            { prompt: "Selecciona especie" },
            class: "w-full border border-outline-variant rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-white" %>
    </div>

    <!-- Weight -->
    <div>
      <%= f.label :weight_kg, "Peso (kg)", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.number_field :weight_kg, step: 0.1, min: 0.1, class: "w-full border border-outline-variant rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-white", placeholder: "Ej. 12.5" %>
    </div>

    <!-- Life stage -->
    <div>
      <%= f.label :life_stage, "Etapa de vida", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.select :life_stage, Pet::LIFE_STAGES.map { |s| [s.capitalize, s] },
            { prompt: "Selecciona etapa" },
            class: "w-full border border-outline-variant rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-white" %>
    </div>

    <!-- Activity level -->
    <div>
      <%= f.label :activity_level, "Nivel de actividad", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.select :activity_level,
            [["Sedentario", "sedentary"], ["Bajo", "low"], ["Moderado", "moderate"], ["Alto", "high"], ["Muy alto", "very_high"]],
            { prompt: "Selecciona nivel" },
            class: "w-full border border-outline-variant rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-white" %>
    </div>

    <!-- BCS -->
    <div>
      <%= f.label :body_condition_score, "Condición corporal (1–9)", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.select :body_condition_score, (1..9).map { |n| [n, n] }, {},
            class: "w-full border border-outline-variant rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-white" %>
      <p class="text-xs text-on-surface-variant mt-1">1 = muy delgado · 5 = ideal · 9 = obeso</p>
    </div>

    <!-- Neutered -->
    <div class="flex items-center gap-3 pt-6">
      <%= f.check_box :is_neutered, class: "w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary" %>
      <%= f.label :is_neutered, "Esterilizado/a", class: "text-sm font-medium text-on-background" %>
    </div>
  </div>

  <!-- Conditions -->
  <% if (all_conditions = Condition.all).any? %>
    <div>
      <p class="text-sm font-semibold text-on-background mb-2">Condiciones médicas</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
        <% all_conditions.each do |condition| %>
          <label class="flex items-center gap-2 text-sm text-on-surface-variant cursor-pointer">
            <%= check_box_tag "pet[condition_ids][]", condition.id,
                  pet.condition_ids.include?(condition.id),
                  class: "rounded border-outline-variant text-primary focus:ring-primary" %>
            <%= condition.name %>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Allergens -->
  <% if (all_allergens = Allergen.all).any? %>
    <div>
      <p class="text-sm font-semibold text-on-background mb-2">Alergias</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
        <% all_allergens.each do |allergen| %>
          <label class="flex items-center gap-2 text-sm text-on-surface-variant cursor-pointer">
            <%= check_box_tag "pet[allergen_ids][]", allergen.id,
                  pet.allergen_ids.include?(allergen.id),
                  class: "rounded border-outline-variant text-primary focus:ring-primary" %>
            <%= allergen.name %>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="flex gap-3 pt-2">
    <%= f.submit pet.new_record? ? "Registrar mascota" : "Guardar cambios",
          class: "bg-primary text-white text-sm font-semibold px-6 py-2.5 rounded-xl hover:bg-primary-container transition-colors cursor-pointer" %>
    <%= link_to "Cancelar", pets_path, class: "text-sm font-medium text-on-surface-variant hover:text-on-background transition-colors px-4 py-2.5" %>
  </div>
<% end %>
