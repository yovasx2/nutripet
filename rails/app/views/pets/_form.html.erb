<!-- Shared form partial for new + edit pet -->
<%= form_with model: pet, class: "space-y-6" do |f| %>
  <% field_class = ->(attr) {
    base = "w-full border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 bg-white "
    pet.errors[attr].any? ? base + "border-red-400 focus:ring-red-400" : base + "border-outline-variant focus:ring-primary"
  } %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <!-- Name -->
    <div>
      <%= f.label :name, class: "block text-sm font-semibold text-on-background mb-1" do %>
        Nombre <span class="text-red-500">*</span>
      <% end %>
      <%= f.text_field :name, class: field_class.(:name), placeholder: "Ej. Luna" %>
      <% if pet.errors[:name].any? %>
        <p class="text-xs text-red-500 mt-1"><%= pet.errors[:name].to_sentence %></p>
      <% end %>
    </div>

    <!-- Breed -->
    <div>
      <%= f.label :breed, "Raza", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.text_field :breed, class: field_class.(:breed), placeholder: "Ej. Labrador" %>
    </div>

    <!-- Species (hidden — dogs only) -->
    <%= f.hidden_field :species, value: "dog" %>

    <!-- Sex -->
    <div>
      <%= f.label :sex, class: "block text-sm font-semibold text-on-background mb-1" do %>
        Sexo <span class="text-red-500">*</span>
      <% end %>
      <%= f.select :sex, Pet::SEX_LABELS.map { |val, label| [label, val] }, { prompt: "Selecciona sexo", selected: pet.new_record? ? nil : pet.sex },
            id: "pet_sex",
            class: field_class.(:sex) %>
      <% if pet.errors[:sex].any? %>
        <p class="text-xs text-red-500 mt-1"><%= pet.errors[:sex].to_sentence %></p>
      <% end %>
    </div>

    <!-- Weight -->
    <div>
      <%= f.label :weight_kg, class: "block text-sm font-semibold text-on-background mb-1" do %>
        Peso (kg) <span class="text-red-500">*</span>
      <% end %>
      <%= f.number_field :weight_kg, step: 0.01, min: 0.1, class: field_class.(:weight_kg), placeholder: "Ej. 12.5" %>
      <% if pet.errors[:weight_kg].any? %>
        <p class="text-xs text-red-500 mt-1"><%= pet.errors[:weight_kg].to_sentence %></p>
      <% end %>
    </div>

    <!-- Age: years + months UI → hidden age_months -->
    <div>
      <%= f.label :age_months, class: "block text-sm font-semibold text-on-background mb-1" do %>
        Edad <span class="text-red-500">*</span>
      <% end %>
      <div class="flex gap-2">
        <div class="flex-1">
          <input type="number" id="age_years_input" min="0" step="1"
                 value="<%= pet.age_months.to_i / 12 %>"
                 class="w-full border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 bg-white border-outline-variant focus:ring-primary"
                 placeholder="Años" />
          <p class="text-xs text-on-surface-variant mt-1">años</p>
        </div>
        <div class="flex-1">
          <input type="number" id="age_months_input" min="0" max="11" step="1"
                 value="<%= pet.age_months.to_i % 12 %>"
                 class="w-full border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 bg-white border-outline-variant focus:ring-primary"
                 placeholder="Meses" />
          <p class="text-xs text-on-surface-variant mt-1">meses (0–11)</p>
        </div>
      </div>
      <%= f.hidden_field :age_months, id: "pet_age_months" %>
      <% if pet.errors[:age_months].any? %>
        <p class="text-xs text-red-500 mt-1"><%= pet.errors[:age_months].to_sentence %></p>
      <% end %>
    </div>

    <!-- Activity level -->
    <div>
      <%= f.label :activity_level, class: "block text-sm font-semibold text-on-background mb-1" do %>
        Nivel de actividad <span class="text-red-500">*</span>
      <% end %>
      <%= f.select :activity_level,
            [["Sedentario", "sedentary"], ["Bajo", "low"], ["Moderado", "moderate"], ["Alto", "high"], ["Muy alto", "very_high"]],
            { prompt: "Selecciona nivel" },
            class: field_class.(:activity_level) %>
      <% if pet.errors[:activity_level].any? %>
        <p class="text-xs text-red-500 mt-1"><%= pet.errors[:activity_level].to_sentence %></p>
      <% end %>
    </div>

    <!-- Condición corporal (BCS) -->
    <div>
      <%= f.label :body_condition_score, "Condición corporal 2–8", class: "block text-sm font-semibold text-on-background mb-1" %>
      <%= f.select :body_condition_score, (2..8).map { |n| [n, n] }, { prompt: "Selecciona condición" },
            class: field_class.(:body_condition_score) %>
      <p class="text-xs text-on-surface-variant mt-1">2 = delgado · 5 = ideal · 8 = obeso</p>
      <% if pet.errors[:body_condition_score].any? %>
        <p class="text-xs text-red-500 mt-1"><%= pet.errors[:body_condition_score].to_sentence %></p>
      <% end %>
    </div>

    <!-- Neutered + reproductive flags -->
    <div class="flex flex-col gap-2 pt-6">
      <div class="flex items-center gap-3">
        <%= f.check_box :is_neutered, class: "w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary" %>
        <%= f.label :is_neutered, "Esterilizado/a", class: "text-sm font-medium text-on-background" %>
      </div>
      <div id="reproductive_flags" class="flex flex-col gap-2 <%= pet.male? ? 'hidden' : '' %>">
        <div class="flex items-center gap-3">
          <%= f.check_box :is_pregnant, class: "w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary" %>
          <%= f.label :is_pregnant, "Gestante", class: "text-sm font-medium text-on-background" %>
        </div>
        <div class="flex items-center gap-3">
          <%= f.check_box :is_lactating, class: "w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary" %>
          <%= f.label :is_lactating, "Lactante", class: "text-sm font-medium text-on-background" %>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var sexSelect = document.getElementById("pet_sex");
      var repFlags  = document.getElementById("reproductive_flags");
      if (!sexSelect || !repFlags) return;
      function toggleRepFlags() {
        repFlags.classList.toggle("hidden", sexSelect.value === "male");
        if (sexSelect.value === "male") {
          repFlags.querySelectorAll("input[type=checkbox]").forEach(function(cb) { cb.checked = false; });
        }
      }
      sexSelect.addEventListener("change", toggleRepFlags);
    })();
  </script>

  <div class="flex gap-3 pt-2">
    <%= f.submit pet.new_record? ? "Registrar mascota" : "Guardar cambios",
          class: "bg-primary text-white text-sm font-semibold px-6 py-2.5 rounded-xl hover:bg-primary-container transition-colors cursor-pointer" %>
    <%= link_to "Cancelar", pets_path, class: "text-sm font-medium text-on-surface-variant hover:text-on-background transition-colors px-4 py-2.5" %>
  </div>
<% end %>

<script>
  (function() {
    var yearsInput  = document.getElementById("age_years_input");
    var monthsInput = document.getElementById("age_months_input");
    var hiddenField = document.getElementById("pet_age_months");
    if (!yearsInput || !monthsInput || !hiddenField) return;

    function syncAgeMonths() {
      var y = parseInt(yearsInput.value, 10)  || 0;
      var m = parseInt(monthsInput.value, 10) || 0;
      hiddenField.value = y * 12 + m;
    }

    // Initialize hidden field on page load
    syncAgeMonths();
    yearsInput.addEventListener("input", syncAgeMonths);
    monthsInput.addEventListener("input", syncAgeMonths);
  })();
</script>
