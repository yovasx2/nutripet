<% content_for :title, "Editar #{@pet.name}" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← #{@pet.name}", pet_path(@pet), class: "text-sm text-primary font-medium hover:underline" %>
    <h1 class="text-2xl font-bold text-on-background mt-2">Editar perfil de <%= @pet.name %></h1>
  </div>
  <div class="bg-white rounded-2xl border border-outline-variant shadow-sm p-6">
    <%= render "form", pet: @pet %>
  </div>

  <div class="mt-6 border-t border-outline-variant pt-6">
    <%= button_to pet_path(@pet), method: :delete,
          data: { confirm: "¿Eliminar a #{@pet.name}? Esta acción no se puede deshacer." },
          class: "text-sm text-red-700 font-medium hover:underline" do %>
      Eliminar mascota
    <% end %>
  </div>
</div>
