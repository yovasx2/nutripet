<% content_for :title, @pet.name %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <!-- Back + actions -->
  <div class="flex items-center justify-between mb-6">
    <%= link_to "← Mis mascotas", pets_path, class: "text-sm text-primary font-medium hover:underline" %>
    <%= link_to "Editar", edit_pet_path(@pet), class: "text-sm text-on-surface-variant border border-outline-variant rounded-xl px-4 py-2 hover:bg-surface-low transition-colors" %>
  </div>

  <!-- Pet card -->
  <div class="bg-white rounded-2xl border border-outline-variant shadow-sm overflow-hidden mb-6">
    <div class="h-2 <%= @pet.dog? ? 'bg-primary' : 'bg-secondary' %>"></div>
    <div class="p-6 grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div>
        <div class="flex items-start justify-between mb-0.5">
          <div>
            <h1 class="text-2xl font-bold text-on-background capitalize"><%= @pet.name %></h1>
            <p class="text-on-surface-variant text-sm capitalize">
              <%= @pet.species_label %> · <%= @pet.breed.presence || "raza no especificada" %>
            </p>
          </div>
          <div class="flex items-center gap-2">
            <% if @pet.female? %>
              <span class="material-symbols-outlined text-5xl leading-none text-pink-400" title="Hembra">female</span>
            <% else %>
              <span class="material-symbols-outlined text-5xl leading-none text-blue-400" title="Macho">male</span>
            <% end %>
            <% if [1, 9].include?(@pet.body_condition_score.to_i) %>
              <span class="relative inline-flex group">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-rose-200 bg-rose-50 text-rose-500">
                  <span class="material-symbols-outlined text-[21px] leading-none">warning</span>
                </span>
              </span>
            <% end %>
          </div>
        </div>
        <div class="flex flex-wrap gap-1 mt-2">
          <% if @pet.is_neutered %>
            <span class="inline-flex items-center gap-1 text-xs bg-surface-low text-on-surface-variant px-2 py-0.5 rounded-full">
              <span class="material-symbols-outlined text-xs leading-none">content_cut</span> Esterilizado/a
            </span>
          <% end %>
          <% if @pet.is_pregnant? %>
            <span class="inline-flex items-center gap-1 text-xs bg-pink-100 text-pink-700 px-2 py-0.5 rounded-full">
              <span class="material-symbols-outlined text-xs leading-none">pregnant_woman</span> Gestante
            </span>
          <% end %>
          <% if @pet.is_lactating? %>
            <span class="inline-flex items-center gap-1 text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full">
              <span class="material-symbols-outlined text-xs leading-none">child_care</span> Lactante
            </span>
          <% end %>
        </div>
      </div>
      <div class="sm:col-span-2 grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
        <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
          <span class="block font-bold text-on-background text-lg"><%= @pet.weight_kg %></span>
          <span class="text-on-surface-variant text-xs">kg</span>
        </div>
        <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
          <span class="block font-bold text-on-background"><%= @pet.life_stage_label %></span>
          <span class="text-on-surface-variant text-xs">Etapa</span>
        </div>
        <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
          <span class="block font-bold text-on-background"><%= @pet.activity_label %></span>
          <span class="text-on-surface-variant text-xs">Actividad</span>
        </div>
        <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
          <span class="block font-bold text-on-background"><%= @pet.body_condition_score %></span>
          <span class="inline-flex items-center justify-center gap-1 text-on-surface-variant text-xs">
            Condición corporal
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Diet section -->
  <div class="bg-white rounded-2xl border border-outline-variant shadow-sm p-6">
    <div class="mb-4">
      <h2 class="text-lg font-bold text-on-background">Dieta Casera</h2>
    </div>

    <% if @latest_diet %>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm mb-4">
        <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
          <span class="block font-bold text-on-background text-lg"><%= @latest_diet.der_kcal.to_i %></span>
          <span class="text-on-surface-variant text-xs">kcal / día</span>
        </div>
        <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
          <span class="block font-bold text-on-background text-lg"><%= @latest_diet.daily_portion_g.to_i %></span>
          <span class="text-on-surface-variant text-xs">g / día</span>
        </div>
        <div class="bg-surface-low rounded-xl px-3 py-2 text-center">
          <span class="block font-bold text-on-background capitalize"><%= @latest_diet.prep_style_label %></span>
          <span class="text-on-surface-variant text-xs">Preparación</span>
        </div>
      </div>
      <%= link_to "Ver dieta completa →", pet_diet_path(@pet, @latest_diet),
            class: "text-sm font-semibold text-primary hover:underline" %>
    <% else %>
      <div class="text-center py-10 bg-surface-low rounded-xl">
        <span class="material-symbols-outlined text-5xl text-outline mb-3 block">restaurant</span>
        <p class="text-on-surface-variant text-sm mb-4">Aún no hay una dieta calculada para <%= @pet.name %>.</p>
        <% if [1, 9].include?(@pet.body_condition_score.to_i) %>
          <p class="text-sm font-semibold text-red-700">Necesita atención veterinaria inmediata antes de calcular su dieta.</p>
        <% else %>
          <%= link_to new_pet_diet_path(@pet),
              class: "inline-flex items-center gap-2 bg-primary text-white text-sm font-semibold px-5 py-2.5 rounded-xl hover:bg-primary-container transition-colors" do %>
            <span class="material-symbols-outlined text-base leading-none">calculate</span>
            Calcular dieta
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
