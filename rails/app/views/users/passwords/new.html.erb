<!DOCTYPE html>

<html class="light" lang="es"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">tailwind.config = {darkMode: "class", theme: {extend: {colors: {primary: "#005d90", "on-primary": "#ffffff", "primary-container": "#0077b6", "on-primary-container": "#f3f7ff", secondary: "#00677d", "on-secondary": "#ffffff", "secondary-container": "#50d9fe", "on-secondary-container": "#005c70", tertiary: "#00626f", "on-tertiary": "#ffffff", "tertiary-container": "#227c8a", "on-tertiary-container": "#e7fbff", error: "#ba1a1a", "on-error": "#ffffff", "error-container": "#ffdad6", "on-error-container": "#93000a", background: "#eefcff", "on-background": "#001f24", surface: "#eefcff", "on-surface": "#001f24", "surface-variant": "#c3e9f1", "on-surface-variant": "#404850", outline: "#707881", "outline-variant": "#bfc7d1", "surface-container-lowest": "#ffffff", "surface-container-low": "#dcf9ff", "surface-container": "#cef5fd", "surface-container-high": "#c9eff7", "surface-container-highest": "#c3e9f1", "primary-fixed-dim": "#94ccff", "on-tertiary-fixed-variant": "#004f59", "inverse-surface": "#0e353c", "secondary-fixed-dim": "#4cd6fb", "surface-tint": "#006399", "on-tertiary-fixed": "#001f24", "on-secondary-fixed": "#001f27", "on-primary-fixed": "#004b74", "primary-fixed": "#cde5ff", "inverse-on-surface": "#d2f7ff", "surface-bright": "#eefcff", "on-primary-fixed-variant": "#004b74", "primary-fixed": "#cde5ff", "inverse-primary": "#94ccff", "tertiary-fixed": "#9feffe", "surface-dim": "#bbe1e8", "tertiary-fixed-dim": "#83d3e1", "on-secondary-fixed-variant": "#004e5f"}, borderRadius: {DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px"}, fontFamily: {headline: ["Plus Jakarta Sans"], body: ["Plus Jakarta Sans"], label: ["Plus Jakarta Sans"], display: "Plus Jakarta Sans"}}}};</script>
<style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-nav { background: rgba(248, 250, 253, 0.6); backdrop-filter: blur(12px); }
        .restorative-mesh {
            background-image: radial-gradient(at 0% 0%, #B0C4DE 0%, transparent 50%), radial-gradient(at 100% 100%, #d6e4f0 0%, transparent 50%);
            opacity: 0.3;
        }
    </style>
</head>
<body class="bg-surface text-on-surface antialiased min-h-screen flex flex-col">
<%= render 'shared/navbar' %>
<main class="relative flex-1 overflow-hidden pt-16">
<div class="absolute inset-0 restorative-mesh -z-10"></div>
<div class="flex-1 flex items-center justify-center px-6 py-6">
<div class="w-full max-w-md">
<div class="bg-surface-container rounded-[2rem] shadow-sm border border-outline-variant overflow-hidden">
<div class="p-6 md:p-8">
<div class="text-center mb-10">
<div class="flex justify-center mb-6">
<div class="bg-primary-container w-16 h-16 rounded-full flex items-center justify-center">
<span class="material-symbols-outlined text-primary text-3xl">medical_services</span>
</div>
</div>
<h1 class="font-headline text-3xl font-extrabold text-on-surface tracking-tight mb-2">Recuperar Contraseña</h1>
<p class="text-on-surface-variant font-body">Ingresa tu correo electrónico para recibir un enlace de recuperación</p>
</div>
<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
<div class="space-y-6">
<div class="space-y-2">
<label class="block font-label text-xs font-bold uppercase tracking-widest text-on-surface-variant ml-4" for="user_email">Correo Electrónico</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-5 top-1/2 -translate-y-1/2 text-outline">mail</span>
<%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full pl-14 pr-6 py-4 bg-surface-container-lowest border border-outline rounded-full focus:ring-2 focus:ring-primary/10 text-on-surface placeholder:text-on-surface-variant transition-all", placeholder: "usuario@ejemplo.com" %>
</div>
<%= render 'users/shared/field_error', resource: resource, field: :email %>
</div>
<button class="w-full py-4 bg-primary text-on-primary font-headline font-bold rounded-full shadow-md hover:bg-primary-container hover:shadow-lg active:scale-95 transition-all flex justify-center items-center gap-2" type="submit">
<span>Enviar enlace de recuperación</span>
<span class="material-symbols-outlined text-lg">send</span>
</button>
</div>
<% end %>
<div class="mt-10 text-center">
<p class="text-on-surface-variant text-sm font-body">
¿Recordaste tu contraseña?
<%= link_to 'Inicia sesión', new_user_session_path, class: "text-primary font-extrabold hover:underline ml-1" %>
</p>
</div>
</div>
</div>
</main>
<%= render 'shared/footer' %>
</body>
</html>
